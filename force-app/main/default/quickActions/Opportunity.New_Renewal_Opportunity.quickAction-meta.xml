<?xml version="1.0" encoding="UTF-8"?>
<QuickAction xmlns="http://soap.sforce.com/2006/04/metadata">
    <description>Creates gov payer renewal or expansion opp</description>
    <fieldOverrides>
        <field>AccountId</field>
        <formula>Opportunity.AccountId</formula>
    </fieldOverrides>
    <fieldOverrides>
        <field>CloseDate</field>
        <formula>IF(
AND(
NOT(ISBLANK(Opportunity.In_Contract_Until__c)),
ISBLANK(Opportunity.SaaS_Offline_Contract_End_Date__c)
),
Opportunity.In_Contract_Until__c,
IF(
AND(
ISBLANK(Opportunity.In_Contract_Until__c),
NOT(ISBLANK(Opportunity.SaaS_Offline_Contract_End_Date__c))
),
Opportunity.SaaS_Offline_Contract_End_Date__c,
IF(
Opportunity.In_Contract_Until__c&gt; Opportunity.SaaS_Offline_Contract_End_Date__c,
Opportunity.In_Contract_Until__c,
Opportunity.SaaS_Offline_Contract_End_Date__c
)
)
) +1</formula>
    </fieldOverrides>
    <fieldOverrides>
        <field>Contract_Start_Date__c</field>
        <formula>IF(
    AND(
       NOT(ISBLANK(Opportunity.In_Contract_Until__c)),
       ISBLANK(Opportunity.SaaS_Offline_Contract_End_Date__c)
    ),
   Opportunity.In_Contract_Until__c,
    IF(
        AND(
            ISBLANK(Opportunity.In_Contract_Until__c),
            NOT(ISBLANK(Opportunity.SaaS_Offline_Contract_End_Date__c))
        ), 
        Opportunity.SaaS_Offline_Contract_End_Date__c,
        IF(
           Opportunity.In_Contract_Until__c&gt; Opportunity.SaaS_Offline_Contract_End_Date__c,
          Opportunity.In_Contract_Until__c,
            Opportunity.SaaS_Offline_Contract_End_Date__c
        )
    )
) +1</formula>
    </fieldOverrides>
    <fieldOverrides>
        <field>Parent_Opportunity__c</field>
        <formula>Opportunity.Id</formula>
    </fieldOverrides>
    <fieldOverrides>
        <field>StageName</field>
        <literalValue>New</literalValue>
    </fieldOverrides>
    <fieldOverrides>
        <field>Type</field>
        <literalValue>Renewal</literalValue>
    </fieldOverrides>
    <label>New Gov Payer Opportunity</label>
    <optionsCreateFeedItem>true</optionsCreateFeedItem>
