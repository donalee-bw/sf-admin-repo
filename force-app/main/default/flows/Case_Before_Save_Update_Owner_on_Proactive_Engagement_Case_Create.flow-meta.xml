        <locationX>0</locationX>
        <locationY>0</locationY>
        <inputAssignments>
            <field>OwnerId</field>
            <value>
                <elementReference>$Record.Account.SaaS_Owner__r.Id</elementReference>
            </value>
        </inputAssignments>
