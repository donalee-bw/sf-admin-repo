    <description>Flow to handle scenarios when there are completed event on SaaS Opps, updates opp owner to ISR and updates stage to rescheduling when demo calls are incomplete or rescheduled, and updates DM Status on opps when demo calls are held or rescheduled by ISR. JH 8/1/23 updated to include gov licensee opps
JH 2/8/24 updated to incorporate PB &quot;Sales Funnel - No Show or Canceled Sales Meetings&quot; which was deactivated
DJ 6.10.24 - updated Prospect Online Booking meeting type = Disco Call, populates disco call completed and demo call completed if became demo on a disco call = true.
08/15/24 - Added OBC Call Completed Date logic.</description>
    <environments>Default</environments>
    <formulas>
        <description>should set the lower value of either the opportunity demo call scheduled or the event&apos;s due date</description>
        <name>forDDemoScheduled</name>
        <dataType>Date</dataType>
        <expression>IF( ISNULL( {!Get_Oppty_Records.Demo_Call_Scheduled__c} ),  {!$Record.ActivityDate} ,
IF( ( {!Get_Oppty_Records.Demo_Call_Scheduled__c} &gt;  {!$Record.ActivityDate} ),  {!$Record.ActivityDate} , {!Get_Oppty_Records.Demo_Call_Scheduled__c}
)
)</expression>
    </formulas>
    <formulas>
        <description>Return the lower value of either the opportunity&apos;s demo call set or the event&apos;s created date</description>
        <name>forDDemoSet</name>
        <dataType>Date</dataType>
        <expression>IF( ISNULL( {!Get_Oppty_Records.Demo_Call_Set__c} ), DATEVALUE( {!$Record.CreatedDate} ),
IF( ( {!Get_Oppty_Records.Demo_Call_Set__c} &gt; DATEVALUE( {!$Record.CreatedDate} )),  DATEVALUE( {!$Record.CreatedDate} ), {!Get_Oppty_Records.Demo_Call_Set__c})
)</expression>
    </formulas>
