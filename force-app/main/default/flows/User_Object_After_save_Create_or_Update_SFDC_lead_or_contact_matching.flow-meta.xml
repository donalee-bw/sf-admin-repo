    <description>When a user record is created or edited, flow looks for a matching contact or lead or creates a contact record if no match found. replaces PB: &quot;Production user record trigger for lead and contact matching&quot; + existing autolaunched flow: &quot;User record to SFDC lead or contact matching</description>
    <environments>Default</environments>
    <formulas>
        <name>First_name_40_logic</name>
        <dataType>String</dataType>
        <expression>IF(
      LEN({!$Record.First_Name__c}) &gt; 40,
      LEFT({!$Record.First_Name__c} , 40),
      {!$Record.First_Name__c}
 )</expression>
    </formulas>
    <formulas>
        <name>Last_Name_logic</name>
        <dataType>String</dataType>
        <expression>IF(
     NOT(ISBLANK({!$Record.Last_Name__c})),
     {!$Record.Last_Name__c},
     &apos;Not Provided&apos;
)</expression>
    </formulas>
    <formulas>
        <name>Owner_logic_for_possible_inactive_user</name>
        <dataType>String</dataType>
        <expression>IF(
     {!Search_for_Account.Owner.IsActive},
     {!Search_for_Account.OwnerId},
     &apos;0053u0000035xeBAAQ&apos;
)</expression>
    </formulas>
    <interviewLabel>User Object - After save - Create or Update - SFDC lead or contact matching {!$Flow.CurrentDateTime}</interviewLabel>
    <label>User Object - After save - Create or Update - SFDC lead or contact matching</label>
