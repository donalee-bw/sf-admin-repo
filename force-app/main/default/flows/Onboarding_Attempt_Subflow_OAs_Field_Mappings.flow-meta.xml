    <description>Subflow responsible for assigning values to fields on SaaS or Billing Onboarding Attempt records from related records. These values will later be used to create or update Onboarding Attempt records via the &quot;Onboarding Attempt - Subflow - Create and Update OAs&quot; flow.

03/03/25 - PE - Updated Billing Status at CW mapping to fix for inactive values
03/10/25 - PE - Updated Combined Funnel Owner formula to account for Goverment Queue
04/08/25 - PE - Updated Billing Status at CW logic
08/08/25 - AC - Updated to add mapping for OBS owner.</description>
    <environments>Default</environments>
    <formulas>
        <name>BillingObAttemptName</name>
        <dataType>String</dataType>
        <expression>{!AccountInput.Name} &amp; &quot; Billing Onboarding Attempt&quot;</expression>
    </formulas>
    <formulas>
        <description>Created to assign current picklist values to the Billing Status at CW field for values that are no longer active and could cause an error.</description>
        <name>BillingStatusAtCW</name>
        <dataType>String</dataType>
        <expression>IF(
  ISPICKVAL({!CombinnelFunnelInput.Billing_Status_at_CW__c}, &quot;Passed to Upsell&quot;),
  &quot;Soft Opt Out&quot;,
  IF(
    ISPICKVAL({!CombinnelFunnelInput.Billing_Status_at_CW__c}, &quot;Opted Out&quot;),
    &quot;Hard Opt Out&quot;,
    TEXT({!CombinnelFunnelInput.Billing_Status_at_CW__c})
  )
)</expression>
    </formulas>
    <formulas>
        <name>CombinedFunnelOwnerStamp</name>
        <dataType>String</dataType>
        <expression>IF(
OR(
{!CombinnelFunnelInput.OwnerId} = &quot;00G3u000002aqp3EAA&quot;,
{!CombinnelFunnelInput.OwnerId} = &quot;00GPB000001orzp2AA&quot;,
{!CombinnelFunnelInput.OwnerId} = &quot;00G3u000002egpzEAA&quot;,
{!CombinnelFunnelInput.OwnerId} = &quot;00GRd000000pTzFMAU&quot;
),
&quot;0053u0000035xeBAAQ&quot;,
{!CombinnelFunnelInput.OwnerId}
)</expression>
    </formulas>
    <formulas>
        <name>SaaSObAttemptName</name>
        <dataType>String</dataType>
        <expression>{!AccountInput.Name} &amp; &quot; SaaS Onboarding Attempt&quot;</expression>
    </formulas>
