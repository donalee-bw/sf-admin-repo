    <environments>Default</environments>
    <formulas>
        <name>CurrentDatePlus15</name>
        <dataType>Date</dataType>
        <expression>{!$Flow.CurrentDate}+15</expression>
    </formulas>
    <formulas>
        <name>CurrentDatePlus90</name>
        <dataType>Date</dataType>
        <expression>{!$Flow.CurrentDate}+90</expression>
    </formulas>
    <formulas>
        <name>EarliestStartTime</name>
        <dataType>DateTime</dataType>
        <expression>DATETIMEVALUE({!$Record.CompletedDateTime})-({!$Record.CallDurationInSeconds}/1440)-10/1440</expression>
    </formulas>
    <formulas>
        <name>RecycleCaseStatement</name>
        <dataType>String</dataType>
        <expression>IF(
  CONTAINS(TEXT({!$Record.Disposition__c}), &apos;REC - Not Interested - COVID19&apos;), &apos;Recycled - COVID-19&apos;,
  IF(
    CONTAINS(TEXT({!$Record.Disposition__c}), &apos;REC - Not Interested - Feature / Product Limitation&apos;), &apos;Recycled - Features Request&apos;,
    IF(
      CONTAINS(TEXT({!$Record.Disposition__c}), &apos;REC - Not Interested - Not Ready Now&apos;), &apos;Recycled - Not Ready&apos;,
      IF(
        CONTAINS(TEXT({!$Record.Disposition__c}), &apos;REC - Not Interested - Price Too High&apos;), &apos;Recycled - No Budget&apos;,
        IF(
          CONTAINS(TEXT({!$Record.Disposition__c}), &apos;REC - Not Interested - Using Competitor&apos;), &apos;Recycled - Using Competitor&apos;,
          &apos;Recycled - Not Interested&apos;
        )
      )
    )
  )
)</expression>
    </formulas>
    <formulas>
        <name>TimesRecycled</name>
        <dataType>Number</dataType>
        <expression>IF(OR(ISBLANK({!Get_Lead_from_Event.Times_Recycled__c}),{!Get_Lead_from_Event.Times_Recycled__c}=0),1,{!Get_Lead_from_Event.Times_Recycled__c}+1)</expression>
        <scale>0</scale>
    </formulas>
