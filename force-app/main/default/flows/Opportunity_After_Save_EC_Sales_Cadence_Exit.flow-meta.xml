    <start>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <connector>
            <targetReference>Is_Contact_in_Active_Cadence_Tracker</targetReference>
        </connector>
        <filterFormula>AND(
{!$Record.RecordTypeId} = {!$Label.Experience_Curriculum_Opportunity},
{!$Record.ContactId} != null, 
  OR ( 
  TEXT({!$Record.Contact__r.Cadence_Label__c}) = &quot;EC - Sales Starter&quot; ,
  TEXT({!$Record.Contact__r.Cadence_Label__c}) = &quot;EC - Sales Missed Demo&quot; ,
  TEXT({!$Record.Contact__r.Cadence_Label__c}) = &quot;EC - Sales Post Demo&quot;

    ),

OR ( 
TEXT({!$Record.StageName}) = &quot;Demo Scheduled&quot;,
TEXT({!$Record.StageName}) = &quot;Rescheduling&quot;,
TEXT({!$Record.StageName}) = &quot;Verbal Agreement&quot;,
TEXT({!$Record.StageName}) = &quot;Delayed Start&quot;,
TEXT({!$Record.StageName}) = &quot;Demo Scheduled&quot;,
TEXT({!$Record.StageName}) = &quot;Closed Won&quot;,
TEXT({!$Record.StageName}) = &quot;Closed Lost&quot;,
TEXT({!$Record.Experience_Curriculum_Demo_Status__c}) = &quot;Scheduled&quot;,
TEXT({!$Record.Experience_Curriculum_Demo_Status__c}) = &quot;Rescheduled&quot;
) 
)</filterFormula>
        <object>Opportunity</object>
