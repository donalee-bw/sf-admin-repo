        <label>Is Conversation Notes Changed</label>
        <locationX>182</locationX>
        <locationY>335</locationY>
        <defaultConnectorLabel>No Updates</defaultConnectorLabel>
        <rules>
            <name>SaaS_or_Billing_Conversation_Notes_were_changed</name>
            <conditionLogic>or</conditionLogic>
            <conditions>
                <leftValueReference>$Record.SaaS_Conversation_Notes__c</leftValueReference>
                <operator>IsChanged</operator>
                <rightValue>
                    <booleanValue>true</booleanValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.Billing_Conversation_Notes__c</leftValueReference>
                <operator>IsChanged</operator>
                <rightValue>
                    <booleanValue>true</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Update_Opportunity_for_SaaS</targetReference>
            </connector>
            <label>SaaS or Billing Conversation Notes were changed</label>
        </rules>
    </decisions>
    <description>When SaaS or Billing Conversation Notes are updated on CF record, update same fields in the billing upsell opportunity record.</description>
