            </conditions>
            <conditions>
                <leftValueReference>Get_AE_Owner_From_The_Account.AE_Owner__r.ManagerId</leftValueReference>
                <operator>IsNull</operator>
                <rightValue>
                    <booleanValue>false</booleanValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>Get_AE_Owner_From_The_Account.AE_Owner__r.Manager.IsActive</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <booleanValue>true</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Send_Slack_Message</targetReference>
            </connector>
            <label>Handoff Issues Set or Updated and AE Manager is Active</label>
        </rules>
    </decisions>
    <description>Sends a slack message to AE managers when the onboarding team selects a picklist value in the OB Handoff Issues field on Combined Funnels.</description>
    <environments>Default</environments>
    <formulas>
        <name>AddedToList</name>
        <dataType>Boolean</dataType>
        <expression>IF(PICKLISTCOUNT({!$Record.OB_Handoff_Issues__c}) &gt; PICKLISTCOUNT(PRIORVALUE({!$Record.OB_Handoff_Issues__c})),true, false)</expression>
    </formulas>
    <formulas>
        <name>TestCountVariable</name>
        <dataType>Number</dataType>
        <expression>IF(
    AND(
            PICKLISTCOUNT({!$Record.OB_Handoff_Issues__c})=0, 
            ISBLANK({!$Record.OB_Handoff_Issues__c})
          ), 
       0, PICKLISTCOUNT({!$Record.OB_Handoff_Issues__c})+1
 )</expression>
        <scale>0</scale>
    </formulas>
