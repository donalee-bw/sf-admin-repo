    <decisions>
        <description>Determines if the OB Handoff picklist has been updated to contain more values</description>
        <name>Is_List_Updated</name>
        <label>Is List Updated</label>
        <locationX>471</locationX>
        <locationY>563</locationY>
        <defaultConnectorLabel>Default Outcome</defaultConnectorLabel>
        <rules>
            <name>Handoff_Issues_Updated_and_Manager_is_Active</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>$Record__Prior.OB_Handoff_Issues__c</leftValueReference>
                <operator>NotEqualTo</operator>
                <rightValue>
                    <elementReference>$Record.OB_Handoff_Issues__c</elementReference>
