        <locationX>767</locationX>
        <locationY>551</locationY>
        <defaultConnector>
            <targetReference>Last_Issue_Update_Datestamp</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>Default Outcome</defaultConnectorLabel>
        <rules>
            <name>AE_Owner_Present_and_Active</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>Get_AE_Owner_From_The_Account</leftValueReference>
