ISCHANGED({!$Record.SaaS_Activation_Override__c}),
TODAY(),
NULL
)</expression>
    </formulas>
    <formulas>
        <name>forT_FunnelStage_SaaSActivationOverrideUpdatedOnCF</name>
        <dataType>String</dataType>
        <expression>IF(
ISCHANGED({!$Record.SaaS_Activation_Override__c}),
&quot;Activated&quot;,
TEXT({!Get_SaaS_Onboarding.Funnel_Stage__c})
)</expression>
    </formulas>
