            <name>Non_Target</name>
            <conditionLogic>2 OR (1 AND 3)</conditionLogic>
            <conditions>
                <leftValueReference>$Record.Account.Current_Premium_ECE__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <booleanValue>false</booleanValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.Account.Customer_Segment__c</leftValueReference>
                <operator>EqualTo</operator>
