    <decisions>
        <description>Validates if account information is new or was updated to trigger school object field updates within the case</description>
        <name>School_Info_Updates</name>
        <label>School Info Updates</label>
        <locationX>182</locationX>
        <locationY>335</locationY>
        <defaultConnectorLabel>Default Outcome</defaultConnectorLabel>
        <rules>
            <name>Brightwheel_Satisfaction_Updated</name>
            <conditionLogic>(1 AND 2) OR (3 AND 4)</conditionLogic>
            <conditions>
                <leftValueReference>$Record.Brightwheel_Satisfaction__c</leftValueReference>
                <operator>NotEqualTo</operator>
                <rightValue>
                    <elementReference>$Record.Account.Brightwheel_Satisfaction__c</elementReference>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.Brightwheel_Satisfaction__c</leftValueReference>
                <operator>IsNull</operator>
                <rightValue>
                    <booleanValue>false</booleanValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record__Prior.Brightwheel_Satisfaction__c</leftValueReference>
                <operator>IsNull</operator>
                <rightValue>
                    <booleanValue>true</booleanValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.Brightwheel_Satisfaction__c</leftValueReference>
                <operator>IsNull</operator>
                <rightValue>
                    <booleanValue>false</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Update_Account_s_BW_Satisfaction</targetReference>
            </connector>
            <label>Brightwheel Satisfaction Updated</label>
        </rules>
    </decisions>
    <description>When Brightwheel Satisfaction is updated in a proactive engagement case, it is also updated in the related account.</description>
