    <environments>Default</environments>
    <formulas>
        <name>fDemoCallNoShow</name>
        <dataType>Boolean</dataType>
        <expression>IF( {!fIsLead}, {!Get_Lead.Demo_Call_No_Show__c},
{!Get_Contact.Demo_Call_No_Show__c})</expression>
    </formulas>
    <formulas>
        <name>fDemoPath</name>
        <dataType>String</dataType>
        <expression>IF( 
{!fIsLead}, TEXT({!Get_Lead.Demo_Path__c}),
TEXT({!Get_Contact.Demo_Path__c})
)</expression>
    </formulas>
    <formulas>
        <name>fHSLastFormSubmissionType</name>
        <dataType>String</dataType>
        <expression>IF( 
{!fIsLead}, TEXT({!Get_Lead.HS_Last_form_submission_type__c}),
TEXT({!Get_Contact.HS_Last_form_submission_type__c})
)</expression>
    </formulas>
    <formulas>
        <name>fIsContact</name>
        <dataType>Boolean</dataType>
        <expression>BEGINS({!TargetId}, &quot;003&quot;)</expression>
    </formulas>
    <formulas>
        <name>fIsLead</name>
        <dataType>Boolean</dataType>
        <expression>BEGINS({!TargetId}, &quot;00Q&quot;)</expression>
    </formulas>
    <formulas>
        <name>fLeanDataRevenueSequenceType</name>
        <dataType>String</dataType>
        <expression>IF( 
{!fIsLead} , TEXT({!Get_Lead.LeanData_Revenue_Sequence_Type__c}),
TEXT({!Get_Contact.LeanData_Revenue_Sequence_Type__c})
)</expression>
    </formulas>
    <formulas>
        <name>fLogicOwnedByQueue</name>
        <dataType>Boolean</dataType>
        <expression>IF( 
{!fIsLead}, {!Get_Lead.LOGIC_Owned_by_queue__c}, 
{!Get_Contact.LOGIC_Owned_by_queue__c} )</expression>
    </formulas>
    <formulas>
        <name>fState</name>
        <dataType>String</dataType>
        <expression>IF( 
{!fIsLead},
{!Get_Lead.State},
{!Get_Contact.MailingState} 
)</expression>
    </formulas>
    <formulas>
        <name>fTargetOwner</name>
        <dataType>String</dataType>
        <expression>IF({!fIsLead}, {!Get_Lead.OwnerId},
{!Get_Contact.OwnerId}
)</expression>
    </formulas>
