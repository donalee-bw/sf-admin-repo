    <description>When Account Type = Inactive Prospect and Account Owner is changed from Account Queue to SDR or ISR, update Account Type to Prospect</description>
    <formulas>
        <processMetadataValues>
            <name>originalFormula</name>
            <value>
                <stringValue>AND(
         ISCHANGED([Account].OwnerId),
         PRIORVALUE([Account].OwnerId) = &apos;0053u0000035xeBAAQ&apos;,
         ISPICKVAL([Account].Type, &apos;Inactive Prospect&apos;),
        OR(   
             [Account].Owner.ProfileId = &apos;00e1I000000qt1EQAQ&apos;,
             [Account].Owner.ProfileId = &apos;00e1I000000qsyPQAQ&apos;, 
             [Account].Owner.ProfileId = &apos;00e3u000000S8lAAAS&apos;
       )
 )</stringValue>
