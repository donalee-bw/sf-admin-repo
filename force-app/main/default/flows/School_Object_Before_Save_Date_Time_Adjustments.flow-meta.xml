    <formulas>
        <description>Sets the Billing Backdated Activation Date only when the Billing Activation Funnel Stage transitions to “Activated” and the activation date is in the past (with a 1-day buffer). This prevents repeated warehouse sync updates from incorrectly marking billing activations as backdated.</description>
        <name>FormBillingBackdatedActivationDate</name>
        <dataType>Date</dataType>
        <expression>IF(
  AND(
    NOT(ISBLANK({!formBillingActivationDate})),

    /* Only evaluate when the Billing funnel stage transitions into Activated */
    TEXT({!$Record.Billing_Activation_Funnel_Stage_2024__c}) = &quot;Activated&quot;,
    TEXT({!$Record__Prior.Billing_Activation_Funnel_Stage_2024__c}) != &quot;Activated&quot;,

    /* Activation date is truly backdated (1-day buffer) */
    DATEVALUE({!formBillingActivationDate}) &lt; (TODAY() - 1)
  ),
  TODAY() - 1,
 {!$Record.Billing_Backdated_Activation_Date__c}
)</expression>
    </formulas>
