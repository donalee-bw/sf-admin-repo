        <dataType>DateTime</dataType>
        <expression>IF(
  RIGHT(TEXT({!$Record.Billing_Activation_Date_2024__c}), 9) = &apos;00:00:00Z&apos;,
  {!$Record.Billing_Activation_Date_2024__c} + (12 / 24),
  {!$Record.Billing_Activation_Date_2024__c}
)</expression>
