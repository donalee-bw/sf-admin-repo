        <description>Sets the SaaS Backdated Activation Date only when the SaaS Activation Funnel Stage transitions to “Activated” and the activation date is in the past (with a 1-day buffer). This prevents duplicate nightly sync updates from incorrectly flagging activations as backdated.</description>
        <name>FormSaasBackdatesActivationDate</name>
        <dataType>Date</dataType>
        <expression>IF(
  AND(
    NOT(ISBLANK({!formSaaSActivationDate})),
    TEXT({!$Record.SaaS_Activation_Funnel_Stage_2024__c}) = &quot;Activated&quot;,
    TEXT({!$Record__Prior.SaaS_Activation_Funnel_Stage_2024__c}) &lt;&gt; &quot;Activated&quot;,
