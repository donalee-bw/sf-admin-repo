    <decisions>
        <name>Cancel_Subscription_Immeidately</name>
        <label>Cancel Subscription Immeidately?</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <defaultConnector>
            <targetReference>Update_Case</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>Default Outcome</defaultConnectorLabel>
        <rules>
            <name>Plan_already_downgraded</name>
            <conditionLogic>or</conditionLogic>
            <conditions>
                <leftValueReference>Get_Case_Record.Brightwheel_Plan__c</leftValueReference>
                <operator>NotEqualTo</operator>
                <rightValue>
                    <stringValue>Premium</stringValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Update_JG_Cancellation_Status</targetReference>
            </connector>
            <label>Plan already downgraded</label>
        </rules>
        <rules>
            <name>Cancel_Immediately</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>Number_of_Sites_Impacted</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <elementReference>Get_Case_Record.Number_of_Sites__c</elementReference>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>Delayed_Subscription_Change_Date</leftValueReference>
                <operator>EqualTo</operator>
            </conditions>
            <connector>
                <targetReference>Send_to_Payload_Builder</targetReference>
            </connector>
            <label>Cancel Immediately</label>
        </rules>
    </decisions>
