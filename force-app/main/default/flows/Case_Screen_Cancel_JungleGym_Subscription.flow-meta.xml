    <formulas>
        <name>for_BillingTerminationDate</name>
        <dataType>Date</dataType>
        <expression>IF(
    AND(
        {!Get_Case_Record.Billing_Verified__c} = &quot;Yes&quot;,
        OR(
            ISBLANK(TEXT({!Get_Case_Record.Cancel_Billing__c})),
            TEXT({!Get_Case_Record.Cancel_Billing__c}) = &quot;Yes&quot;
        )
    ),
    IF(
        ISBLANK({!Get_Case_Record.Payment_Period_End_Date__c}),
        TODAY(),
        DATEVALUE({!Get_Case_Record.Payment_Period_End_Date__c})
    ),
    NULL
)</expression>
    </formulas>
