    <decisions>
        <description>Checks if the contact listed on the opportunity was changed. If true, wipe out the value from the BIlling Upsell Opportunity stage field for the previous contact.</description>
        <name>Contact_Updated_BU</name>
        <label>Contact Updated?</label>
        <locationX>182</locationX>
        <locationY>1631</locationY>
        <defaultConnector>
            <targetReference>Update_Contact_BU</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>No</defaultConnectorLabel>
        <rules>
            <name>Yes_Contact_Updated_BU</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>$Record__Prior.Contact__c</leftValueReference>
                <operator>NotEqualTo</operator>
                <rightValue>
                    <elementReference>$Record.Contact__c</elementReference>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record__Prior.ContactId</leftValueReference>
                <operator>IsNull</operator>
                <rightValue>
                    <booleanValue>false</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Wipe_Out_Previous_Contact_Fields_BU</targetReference>
            </connector>
            <label>Yes</label>
        </rules>
    </decisions>
