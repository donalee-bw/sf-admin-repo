    <decisions>
        <description>Checks if the stage of an opportunity was updated or if a new contact was associated with that opportunity. If a new contact was added, then the opportunity stage should be stamped.</description>
        <name>Stage_Updated_or_Contact_Added</name>
        <label>Stage Updated or Contact Added?</label>
        <locationX>1392</locationX>
        <locationY>431</locationY>
        <defaultConnectorLabel>No</defaultConnectorLabel>
        <rules>
            <name>Yes_Stage_Updated_or_Contact_Added</name>
            <conditionLogic>1 OR (2 AND 3)</conditionLogic>
            <conditions>
                <leftValueReference>$Record.StageName</leftValueReference>
                <operator>IsChanged</operator>
                <rightValue>
                    <booleanValue>true</booleanValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.Contact__r.Id</leftValueReference>
                <operator>NotEqualTo</operator>
                <rightValue>
                    <elementReference>$Record__Prior.Contact__r.Id</elementReference>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.Contact__r.Id</leftValueReference>
                <operator>IsNull</operator>
                <rightValue>
                    <booleanValue>false</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Opportunity_Record_Type</targetReference>
            </connector>
            <label>Yes</label>
        </rules>
    </decisions>
