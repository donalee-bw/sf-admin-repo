<?xml version="1.0" encoding="UTF-8"?>
<Flow xmlns="http://soap.sforce.com/2006/04/metadata">
    <apiVersion>59.0</apiVersion>
    <areMetricsLoggedToDataCloud>false</areMetricsLoggedToDataCloud>
    <description>replaces process builder: Original lead id and ensures missing fields are stamped for revenue.io generated tasks that are used in analytics and reporting
adding in additional path for outreach created tasks
JH 1/5/23: updated to be create only + path for intercom chats to update activity type C= --&gt; chat</description>
    <environments>Default</environments>
    <formulas>
        <name>original18DigitID</name>
        <dataType>String</dataType>
        <expression>CASESAFEID({!$Record.WhoId})</expression>
    </formulas>
    <interviewLabel>Task - Stamp original lead id and snapshot fields on create {!$Flow.CurrentDateTime}</interviewLabel>
    <label>Task - Stamp original lead id and snapshot fields on create</label>
    <processMetadataValues>
        <name>BuilderType</name>
        <value>
            <stringValue>LightningFlowBuilder</stringValue>
        </value>
    </processMetadataValues>
    <processMetadataValues>
        <name>CanvasMode</name>
        <value>
            <stringValue>AUTO_LAYOUT_CANVAS</stringValue>
        </value>
    </processMetadataValues>
    <processMetadataValues>
        <name>OriginBuilderType</name>
        <value>
            <stringValue>LightningFlowBuilder</stringValue>
        </value>
    </processMetadataValues>
    <processType>AutoLaunchedFlow</processType>
    <recordUpdates>
        <name>Update_originalleadID</name>
        <label>Update originalleadID &amp; role snapshots</label>
        <locationX>176</locationX>
        <locationY>287</locationY>
        <inputAssignments>
            <field>Assigned_To_Role_Snapshot__c</field>
            <value>
                <elementReference>$Record.Owner:User.UserRole.Name</elementReference>
            </value>
        </inputAssignments>
        <inputAssignments>
            <field>Booked_By_Role_Snapshot__c</field>
            <value>
                <elementReference>$Record.Booked_By__r.UserRole.Name</elementReference>
            </value>
        </inputAssignments>
        <inputAssignments>
            <field>Original_Lead_ID__c</field>
            <value>
                <elementReference>original18DigitID</elementReference>
            </value>
        </inputAssignments>
        <inputReference>$Record</inputReference>
    </recordUpdates>
    <start>
        <locationX>50</locationX>
        <locationY>0</locationY>
        <connector>
            <targetReference>Update_originalleadID</targetReference>
        </connector>
        <filterLogic>and</filterLogic>
        <filters>
            <field>WhoId</field>
            <operator>IsNull</operator>
            <value>
                <booleanValue>false</booleanValue>
            </value>
        </filters>
        <object>Task</object>
        <recordTriggerType>Create</recordTriggerType>
        <triggerType>RecordBeforeSave</triggerType>
    </start>
    <status>Active</status>
</Flow>
