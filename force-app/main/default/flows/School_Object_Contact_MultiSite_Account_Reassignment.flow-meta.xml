            </conditions>
            <conditions>
                <leftValueReference>forIndirectSaaSFunnelLevel</leftValueReference>
                <operator>NotEqualTo</operator>
                <rightValue>
                    <numberValue>8.0</numberValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>forDirectSaaSFunnelLevel</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <numberValue>8.0</numberValue>
                </rightValue>
            </conditions>
            <conditions>
