    <description>pass the contactId into the recordId to create an EC opportunity
JH 10/30/24- updated to assign the Inbound or outbound field value based on the opportunity source field
BW 07/30/25 - Added logic based on EC Previously Purchased flag</description>
    <environments>Default</environments>
    <formulas>
        <name>forInboundorOutbound</name>
        <dataType>String</dataType>
        <expression>IF(
    OR(TEXT({!varTempOpportunity.Opportunity_Source__c}) = &quot;Chat (Intercom)&quot;, 
           TEXT({!varTempOpportunity.Opportunity_Source__c}) = &quot;Mixpanel&quot;,
           TEXT({!varTempOpportunity.Opportunity_Source__c}) = &quot;Inbound Form&quot;,
           TEXT({!varTempOpportunity.Opportunity_Source__c}) = &quot;Referral&quot;,
           TEXT({!varTempOpportunity.Opportunity_Source__c}) = &quot;Re-engage&quot;
           ),
    &quot;Inbound&quot;,
    IF(
        OR(TEXT({!varTempOpportunity.Opportunity_Source__c}) = &quot;Cancelled/Churn&quot;, 
              TEXT({!varTempOpportunity.Opportunity_Source__c}) = &quot;Cold Call&quot;,
              TEXT({!varTempOpportunity.Opportunity_Source__c}) = &quot;Closed Lost&quot; ,
              TEXT({!varTempOpportunity.Opportunity_Source__c}) = &quot;Expired Pre Paid&quot;
              ),
        &quot;Outbound&quot;,
        &quot;Outbound&quot;
    )
)</expression>
    </formulas>
    <formulas>
        <name>formCloseDate</name>
        <dataType>Date</dataType>
        <expression>{!$Flow.CurrentDate} + 30</expression>
    </formulas>
    <formulas>
        <name>formOpportunityName</name>
        <dataType>String</dataType>
        <expression>{!Get_Contact.Account.Name} &amp; &quot; - Experience Curriculum &quot; &amp; TEXT(Month( TODAY())) &amp; &quot;/&quot; &amp; TEXT(Year(TODAY()))</expression>
    </formulas>
    <formulas>
        <name>formToday</name>
        <dataType>Date</dataType>
        <expression>TODAY()</expression>
    </formulas>
    <formulas>
        <name>forOppSource</name>
        <dataType>String</dataType>
        <expression>IF(
  ISPICKVAL({!Get_Contact.EC_Previously_Purchased__c}, &apos;Yes&apos;),
  &apos;Re-engage&apos;,
  IF(
    NOT(ISBLANK(TEXT({!Get_Contact.DataOps_Data_Source__c}))),
    TEXT({!Get_Contact.DataOps_Data_Source__c}),
    TEXT({!Get_Contact.Opportunity_Source__c})
  )
)</expression>
    </formulas>
