<?xml version="1.0" encoding="UTF-8"?>
<Flow xmlns="http://soap.sforce.com/2006/04/metadata">
    <apiVersion>59.0</apiVersion>
    <areMetricsLoggedToDataCloud>false</areMetricsLoggedToDataCloud>
    <decisions>
        <description>Checks if the prospect (WhoId) associated with the Task is a contact or a lead</description>
        <name>Contact_or_Lead</name>
        <label>Contact or Lead?</label>
        <locationX>182</locationX>
        <locationY>323</locationY>
        <defaultConnector>
            <targetReference>Update_Lead_Latest_Disposition</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>Lead</defaultConnectorLabel>
        <rules>
            <name>Contact</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>$Record.WhoId</leftValueReference>
                <operator>StartsWith</operator>
                <rightValue>
                    <stringValue>003</stringValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Update_Contact_Latest_Disposition</targetReference>
            </connector>
            <label>Contact</label>
        </rules>
    </decisions>
    <description>PE - This flow corrects an issue where a call&apos;s disposition, assigned by a rep during the call, creates a task with the right disposition but fails to update the corresponding Contact or Lead. The flow ensures this value is properly passed to the prospect&apos;s record. (Revenue.io Implementation Project)</description>
    <environments>Default</environments>
    <formulas>
        <name>isNew</name>
        <dataType>Boolean</dataType>
        <expression>isNew()</expression>
    </formulas>
    <interviewLabel>Task - After Save - Update Prospect Call Result {!$Flow.CurrentDateTime}</interviewLabel>
    <label>Task - After Save - Update Prospect Call Result</label>
    <processMetadataValues>
        <name>BuilderType</name>
        <value>
            <stringValue>LightningFlowBuilder</stringValue>
        </value>
    </processMetadataValues>
    <processMetadataValues>
        <name>CanvasMode</name>
        <value>
            <stringValue>AUTO_LAYOUT_CANVAS</stringValue>
        </value>
    </processMetadataValues>
    <processMetadataValues>
        <name>OriginBuilderType</name>
        <value>
            <stringValue>LightningFlowBuilder</stringValue>
        </value>
    </processMetadataValues>
    <processType>AutoLaunchedFlow</processType>
    <recordUpdates>
        <name>Update_Contact_Latest_Disposition</name>
        <label>Update Contact Latest Disposition</label>
        <locationX>50</locationX>
        <locationY>431</locationY>
        <filterLogic>and</filterLogic>
        <filters>
            <field>Id</field>
            <operator>EqualTo</operator>
            <value>
                <elementReference>$Record.WhoId</elementReference>
            </value>
        </filters>
        <filters>
            <field>ringdna100__Latest_Disposition__c</field>
            <operator>NotEqualTo</operator>
            <value>
                <elementReference>$Record.CallDisposition</elementReference>
            </value>
        </filters>
        <inputAssignments>
            <field>ringdna100__Latest_Disposition__c</field>
            <value>
                <elementReference>$Record.CallDisposition</elementReference>
            </value>
        </inputAssignments>
        <object>Contact</object>
    </recordUpdates>
    <recordUpdates>
        <name>Update_Lead_Latest_Disposition</name>
        <label>Update Lead Latest Disposition</label>
        <locationX>314</locationX>
        <locationY>431</locationY>
        <filterLogic>and</filterLogic>
        <filters>
            <field>Id</field>
            <operator>EqualTo</operator>
            <value>
                <elementReference>$Record.WhoId</elementReference>
            </value>
        </filters>
        <filters>
            <field>ringdna100__Latest_Disposition__c</field>
            <operator>NotEqualTo</operator>
            <value>
                <elementReference>$Record.CallDisposition</elementReference>
            </value>
        </filters>
        <inputAssignments>
            <field>ADMIN_Duplicate_Tag__c</field>
            <value>
                <stringValue>Updated via Task Update</stringValue>
            </value>
        </inputAssignments>
        <inputAssignments>
            <field>ringdna100__Latest_Disposition__c</field>
            <value>
                <elementReference>$Record.CallDisposition</elementReference>
            </value>
        </inputAssignments>
        <object>Lead</object>
    </recordUpdates>
    <start>
        <locationX>56</locationX>
        <locationY>0</locationY>
        <connector>
            <targetReference>Contact_or_Lead</targetReference>
        </connector>
        <filterFormula>AND(
  ISPICKVAL({!$Record.Type},&quot;Call&quot;),
  ISPICKVAL({!$Record.TaskSubtype},&quot;Call&quot;),
  NOT(ISBLANK({!$Record.WhoId})),
  NOT(ISBLANK({!$Record.CallDisposition})),
OR(
   ISCHANGED({!$Record.CallDisposition}),
   ISNEW()
  )
)</filterFormula>
        <object>Task</object>
        <recordTriggerType>CreateAndUpdate</recordTriggerType>
        <triggerType>RecordAfterSave</triggerType>
    </start>
    <status>Obsolete</status>
</Flow>
