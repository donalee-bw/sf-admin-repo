<?xml version="1.0" encoding="UTF-8"?>
<Flow xmlns="http://soap.sforce.com/2006/04/metadata">
    <apiVersion>61.0</apiVersion>
    <areMetricsLoggedToDataCloud>false</areMetricsLoggedToDataCloud>
    <description>Screenflow that calls 2 subflows to create the EC Onboarding record and the SFDC Task based sequence</description>
    <environments>Default</environments>
    <interviewLabel>Opportunity - Screenflow - Create EC Onboarding + Task Based Sequence {!$Flow.CurrentDateTime}</interviewLabel>
