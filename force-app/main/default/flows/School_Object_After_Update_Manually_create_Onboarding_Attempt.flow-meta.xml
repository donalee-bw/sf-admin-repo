    <areMetricsLoggedToDataCloud>false</areMetricsLoggedToDataCloud>
    <decisions>
        <name>Billing_Upsell_CW_exists</name>
        <label>Billing Upsell CW exists?</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <defaultConnectorLabel>Default Outcome</defaultConnectorLabel>
        <rules>
            <name>Billing_Upsell_CW_exists_and_CloseDate_more_recent</name>
            <conditionLogic>1 AND ( 2 OR 3) AND 4 AND 5</conditionLogic>
            <conditions>
                <leftValueReference>Get_Latest_Billing_Upsell_CW</leftValueReference>
                <operator>IsNull</operator>
                <rightValue>
                    <booleanValue>false</booleanValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>Get_Latest_Billing_Upsell_CW.CloseDate</leftValueReference>
                <operator>GreaterThan</operator>
                <rightValue>
                    <elementReference>Get_Latest_SaasOrGov_CW.CloseDate</elementReference>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>Get_Latest_SaasOrGov_CW</leftValueReference>
                <operator>IsNull</operator>
                <rightValue>
                    <booleanValue>true</booleanValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>Get_Related_Account</leftValueReference>
                <operator>IsNull</operator>
                <rightValue>
                    <booleanValue>false</booleanValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>Get_Final_Combined_Funnel</leftValueReference>
                <operator>IsNull</operator>
                <rightValue>
                    <booleanValue>false</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Create_Billing_Onboarding_Attempt</targetReference>
            </connector>
            <label>Billing Upsell CW exists and CloseDate more recent</label>
        </rules>
    </decisions>
    <decisions>
        <name>SaaS_Gov_CW_Exists</name>
        <label>SaaS/Gov CW Exists?</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <defaultConnector>
            <targetReference>Billing_Upsell_CW_exists</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>Default Outcome</defaultConnectorLabel>
        <rules>
            <name>SaaS_Gov_CW_opp_exists</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>Get_Latest_SaasOrGov_CW</leftValueReference>
                <operator>IsNull</operator>
                <rightValue>
                    <booleanValue>false</booleanValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>Get_Related_Account</leftValueReference>
                <operator>IsNull</operator>
                <rightValue>
                    <booleanValue>false</booleanValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>Get_Final_Combined_Funnel</leftValueReference>
                <operator>IsNull</operator>
                <rightValue>
                    <booleanValue>false</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Create_SaaS_Onboarding_Attempts</targetReference>
            </connector>
            <label>SaaS/Gov CW opp exists</label>
        </rules>
    </decisions>
    <description>This flow will be used to trigger the creation of Onboarding Attempts from the School Object record.</description>
