<?xml version="1.0" encoding="UTF-8"?>
<Flow xmlns="http://soap.sforce.com/2006/04/metadata">
    <apiVersion>64.0</apiVersion>
    <areMetricsLoggedToDataCloud>false</areMetricsLoggedToDataCloud>
    <assignments>
        <name>Assign_Opp_Values</name>
        <label>Assign Opp Values</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <assignmentItems>
            <assignToReference>Get_Opportunity.Experience_Curriculum_Demo_Held__c</assignToReference>
            <operator>Assign</operator>
            <value>
                <elementReference>formDemoHeldDate</elementReference>
            </value>
        </assignmentItems>
        <assignmentItems>
            <assignToReference>Get_Opportunity.Experience_Curriculum_Demo_Date__c</assignToReference>
            <operator>Assign</operator>
            <value>
                <elementReference>$Record.ActivityDate</elementReference>
            </value>
        </assignmentItems>
        <assignmentItems>
            <assignToReference>Get_Opportunity.Experience_Curriculum_Demos_Scheduled__c</assignToReference>
            <operator>Assign</operator>
            <value>
                <elementReference>formNumofDemos</elementReference>
            </value>
        </assignmentItems>
        <assignmentItems>
            <assignToReference>Get_Opportunity.EC_Validation_Error__c</assignToReference>
            <operator>Assign</operator>
        </assignmentItems>
        <connector>
            <targetReference>Assign_Opp_Values_more</targetReference>
        </connector>
    </assignments>
    <assignments>
        <name>Assign_Opp_Values_more</name>
        <label>Assign Opp Values (more)</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <assignmentItems>
            <assignToReference>Get_Opportunity.Experience_Curriculum_Demo_Status__c</assignToReference>
            <operator>Assign</operator>
            <value>
                <elementReference>formDemoStatus</elementReference>
            </value>
        </assignmentItems>
        <connector>
            <targetReference>Update_Opp</targetReference>
        </connector>
    </assignments>
    <decisions>
        <name>Found_Opp_decision</name>
        <label>Found Opp decision</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <defaultConnectorLabel>No Opp</defaultConnectorLabel>
        <rules>
            <name>Found_Opp</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>Get_Opportunity.Id</leftValueReference>
                <operator>IsNull</operator>
                <rightValue>
                    <booleanValue>false</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Assign_Opp_Values</targetReference>
            </connector>
            <label>Found Opp</label>
        </rules>
    </decisions>
    <description>Assigns values for the Experience Curriculum Demo Held. Experience Curriculum Demo Date Experience Curriculum Demos Scheduled and Experience Curriculum Demo Status on the Opportunity
lk- 10.03.2025 - Updated the DemoStatus formula by removing the     {!$Record.Rescheduled_CP__c} &gt; 0 for rescheduling
LK - 10.08.2025 - For Go-Live, removed the hardcoded IDs in the entry criteria.
LK- 10.08.2025 - Added to null out the EC Validation Error - when updating the EC Demo</description>
    <environments>Default</environments>
    <formulas>
        <name>formDemoHeldDate</name>
        <dataType>Date</dataType>
        <expression>IF({!$Record.Meeting_Completed__c} = TRUE,{!$Record.ActivityDate}, NULL)</expression>
    </formulas>
    <formulas>
        <name>formDemoStatus</name>
        <dataType>String</dataType>
        <expression>IF(
  {!$Record.Meeting_Completed__c} = TRUE,
  &apos;Completed&apos;,
  IF(
    AND(
      OR(
        {!$Record.No_Show_CP__c} = TRUE,
        {!$Record.No_Show__c} = TRUE,
        {!$Record.Canceled_CP__c} = TRUE,
        {!$Record.Canceled__c} = TRUE,
        {!$Record.Meeting_Incomplete__c} = TRUE,
        {!$Record.Meeting_Rescheduled_by_ISR__c} = TRUE
      ),
      {!Get_Opportunity.Experience_Curriculum_Demos_Scheduled__c} = 1
    ),
    &apos;Rescheduling&apos;,
    IF(
OR(
      {!Get_Opportunity.Experience_Curriculum_Demos_Scheduled__c} &gt; 1,
      {!$Record.Rescheduled_CP__c} &gt; 0 ), 
      &apos;Rescheduled&apos;,
        &apos;Scheduled&apos;
      )
    )
  )</expression>
    </formulas>
    <formulas>
        <name>formNumofDemos</name>
        <dataType>Number</dataType>
        <expression>IF(
  {!$Record.Counted_on_Opportunity__c} = FALSE,
  IF(
    ISNULL({!Get_Opportunity.Experience_Curriculum_Demos_Scheduled__c}),
    1,
    {!Get_Opportunity.Experience_Curriculum_Demos_Scheduled__c} + 1
  ),
  {!Get_Opportunity.Experience_Curriculum_Demos_Scheduled__c}
)</expression>
        <scale>2</scale>
    </formulas>
    <interviewLabel>Sales Funnel - EC Event Handler {!$Flow.CurrentDateTime}</interviewLabel>
    <label>Sales Funnel - EC Event Handler</label>
    <processMetadataValues>
        <name>BuilderType</name>
        <value>
            <stringValue>LightningFlowBuilder</stringValue>
        </value>
    </processMetadataValues>
    <processMetadataValues>
        <name>CanvasMode</name>
        <value>
            <stringValue>AUTO_LAYOUT_CANVAS</stringValue>
        </value>
    </processMetadataValues>
    <processMetadataValues>
        <name>OriginBuilderType</name>
        <value>
            <stringValue>LightningFlowBuilder</stringValue>
        </value>
    </processMetadataValues>
    <processType>AutoLaunchedFlow</processType>
    <recordLookups>
        <name>Get_Opportunity</name>
        <label>Get Opportunity</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <assignNullValuesIfNoRecordsFound>false</assignNullValuesIfNoRecordsFound>
        <connector>
            <targetReference>Found_Opp_decision</targetReference>
        </connector>
        <filterLogic>and</filterLogic>
        <filters>
            <field>Id</field>
            <operator>EqualTo</operator>
            <value>
                <elementReference>$Record.WhatId</elementReference>
            </value>
        </filters>
        <getFirstRecordOnly>true</getFirstRecordOnly>
        <object>Opportunity</object>
        <storeOutputAutomatically>true</storeOutputAutomatically>
    </recordLookups>
    <recordUpdates>
        <name>Update_Event</name>
        <label>Update Event</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <inputAssignments>
            <field>Counted_on_Opportunity__c</field>
            <value>
                <booleanValue>true</booleanValue>
            </value>
        </inputAssignments>
        <inputReference>$Record</inputReference>
    </recordUpdates>
    <recordUpdates>
        <name>Update_Opp</name>
        <label>Update Opp</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <connector>
            <targetReference>Update_Event</targetReference>
        </connector>
        <inputReference>Get_Opportunity</inputReference>
    </recordUpdates>
    <start>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <connector>
            <targetReference>Get_Opportunity</targetReference>
        </connector>
        <filterLogic>1 AND 2</filterLogic>
        <filters>
            <field>LOGIC_EC_Demo__c</field>
            <operator>EqualTo</operator>
            <value>
                <booleanValue>true</booleanValue>
            </value>
        </filters>
        <filters>
            <field>WhatId</field>
            <operator>StartsWith</operator>
            <value>
                <stringValue>006</stringValue>
            </value>
        </filters>
        <object>Event</object>
        <recordTriggerType>CreateAndUpdate</recordTriggerType>
        <triggerType>RecordAfterSave</triggerType>
    </start>
    <status>Active</status>
</Flow>
