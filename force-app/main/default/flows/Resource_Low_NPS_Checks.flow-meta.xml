    <decisions>
        <description>Filters record if the NPS Score is populated and less than 9. Records with NPS Score of &lt;9 will not create a case.</description>
        <name>NPS_Score</name>
        <label>NPS Score</label>
        <locationX>1040</locationX>
        <locationY>863</locationY>
        <defaultConnectorLabel>NPS over 9-10</defaultConnectorLabel>
        <rules>
            <name>NPS_9_10</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>$Record.Wootric__Score__c</leftValueReference>
                <operator>IsNull</operator>
                <rightValue>
                    <booleanValue>false</booleanValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.Wootric__Score__c</leftValueReference>
                <operator>LessThan</operator>
                <rightValue>
                    <numberValue>9.0</numberValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.Wootric__Contact__r.Account.Customer_Segment__c</leftValueReference>
                <operator>NotEqualTo</operator>
                <rightValue>
                    <stringValue>Micro</stringValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>ASN_New_Proactive_Engagement_Case</targetReference>
            </connector>
            <label>NPS under 9-10</label>
        </rules>
    </decisions>
