SUBSTITUTE($Label.NewLine , &quot;-&quot;, &quot;&quot;)  &amp;
&apos;*First Name:* &apos; &amp; {!$Record.FirstName}  &amp;
SUBSTITUTE($Label.NewLine , &quot;-&quot;, &quot;&quot;)  &amp; 
&apos;*Last Name:* &apos; &amp; {!$Record.LastName}  &amp;
SUBSTITUTE($Label.NewLine , &quot;-&quot;, &quot;&quot;)  &amp; 
&apos;*Email:* &apos; &amp; {!$Record.Email} &amp;
SUBSTITUTE($Label.NewLine , &quot;-&quot;, &quot;&quot;)  &amp; 
&apos;*Phone:* &apos; &amp; {!$Record.Phone} &amp;
SUBSTITUTE($Label.NewLine , &quot;-&quot;, &quot;&quot;)  &amp; 
