    <description>When SaaS Threshold Dates are updated on the School Object, flow updates SaaS funnel data (Threshold Date Stamp fields and Funnel Stage) on the Active, Non-Activated SaaS Onboarding record that is related to the Account the School Object is tied to. Used for &apos;stamping&apos; activation data on SaaS onboardings at the moment in time - for future historical reference to non-changing activation information.</description>
    <formulas>
        <name>ActivityThresholdMetStamp</name>
        <dataType>Date</dataType>
        <expression>IF(
    ISBLANK({!Get_onboarding.Activity_Threshold_Met_Stamp__c}),
    DATEVALUE({!School_object.Activity_Threshold_Met_Date__c})+1, {!Get_onboarding.Activity_Threshold_Met_Stamp__c}
)</expression>
    </formulas>
    <formulas>
        <name>InitialSetupCallCompletedStamp</name>
        <dataType>Date</dataType>
        <expression>IF(
     ISBLANK({!Get_onboarding.Initial_Setup_Call_Completed_Stamp__c}),
     {!Get_onboarding.Initial_Setup_Call_Completed__c}, {!Get_onboarding.Initial_Setup_Call_Completed_Stamp__c}
)</expression>
    </formulas>
    <formulas>
        <name>InitialStudentsThresholdMetStamp</name>
        <dataType>Date</dataType>
        <expression>IF(
    ISBLANK({!Get_onboarding.Initial_Students_Threshold_Met_Stamp__c}),
    DATEVALUE({!School_object.Initial_Students_Threshold_Met_Date__c})+1, {!Get_onboarding.Initial_Students_Threshold_Met_Stamp__c}
)</expression>
    </formulas>
    <formulas>
        <name>OnboardingTrainingCallCompletedStamp</name>
        <dataType>Date</dataType>
        <expression>IF(
   ISBLANK({!Get_onboarding.Onboarding_Training_Call_Completed_Stamp__c}),
   {!Get_onboarding.Onboarding_Call_Complete__c}, {!Get_onboarding.Onboarding_Training_Call_Completed_Stamp__c}
)</expression>
    </formulas>
    <formulas>
        <name>OriginalCloseDateStamp</name>
        <dataType>Date</dataType>
        <expression>IF(
    ISBLANK({!Get_onboarding.Original_Close_Date_Stamp__c}),
    {!Get_onboarding.Original_Close_Date__c}, {!Get_onboarding.Original_Close_Date_Stamp__c}
)</expression>
    </formulas>
    <formulas>
        <name>ParentsActivatedThresholdMetStamp</name>
        <dataType>Date</dataType>
        <expression>IF(
    ISBLANK({!Get_onboarding.Parents_Activated_Threshold_Met_Stamp__c}),
    DATEVALUE({!School_object.Parents_Activated_Threshold_Met_Date__c})+1, {!Get_onboarding.Parents_Activated_Threshold_Met_Stamp__c}
)</expression>
    </formulas>
    <formulas>
        <name>SaaSActivationDateStamp</name>
        <dataType>Date</dataType>
        <expression>IF(
    ISBLANK({!Get_onboarding.SaaS_Activation_Date_Stamp__c}),
    {!School_object.Date_of_Activation__c}, {!Get_onboarding.SaaS_Activation_Date_Stamp__c}
)</expression>
    </formulas>
    <formulas>
        <name>StudentEnrollmentThresholdMetStamp</name>
        <dataType>Date</dataType>
        <expression>IF(
    ISBLANK({!Get_onboarding.Student_Enrollment_Threshold_Met_Stamp__c}),
    DATEVALUE({!School_object.Student_Enrollment_Threshold_Met_Date__c})+1, {!Get_onboarding.Student_Enrollment_Threshold_Met_Stamp__c}
)</expression>
    </formulas>
