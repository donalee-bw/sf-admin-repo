    <start>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <connector>
            <targetReference>Get_School_Object</targetReference>
        </connector>
        <filterFormula>AND(
    TEXT({!$Record.Cadence_Label__c}) = &quot;Core Onboarding - BNP&quot;,
    OR(
          TEXT({!$Record.New_Case_Type__c}) = &quot;Cancel Request&quot;,
        AND(
            TEXT({!$Record.SaaS_Activation_Funnel_Stage_2024__c}) = &quot;Activated&quot;,
            OR(
                AND(
                    TEXT({!$Record.Billing_Activation_Funnel_Stage_2024__c}) = &quot;Activated&quot;,
                    TEXT({!$Record__Prior.Billing_Activation_Funnel_Stage_2024__c}) &lt;&gt; &quot;Activated&quot;
                ),
                AND(
                    TEXT({!$Record.Account.Billing_Onboarding_Status__c}) = &quot;Opted Out&quot;,
                    TEXT({!$Record__Prior.Account.Billing_Onboarding_Status__c}) &lt;&gt; &quot;Opted Out&quot;
                ),
                AND(
                    ISBLANK({!$Record.Account.Billing_Activation_Start_Date__c}),
                    NOT(
                        ISBLANK({!$Record__Prior.Account.Billing_Activation_Start_Date__c})
                    )
                )
            )
        )
    )
)</filterFormula>
