        <locationX>182</locationX>
        <locationY>431</locationY>
        <defaultConnector>
            <targetReference>Update_Account_Owner_and_OBS_Owner</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>All Else</defaultConnectorLabel>
        <rules>
            <name>Self_Serve_Gov_Stand_Path_Queue</name>
            <conditionLogic>or</conditionLogic>
            <conditions>
                <leftValueReference>$Record.Owner:Group.Id</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>00G3u000002aqp3EAA</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.Owner:Group.Id</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>00GRd000000pTzFMAU</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.Owner:Group.Id</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>00GPB000001orzp2AA</stringValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Copy_1_of_Update_Account_Owner_and_OBS_Owner</targetReference>
            </connector>
            <label>Self Serve/Gov/ Stand Path Queue</label>
        </rules>
    </decisions>
