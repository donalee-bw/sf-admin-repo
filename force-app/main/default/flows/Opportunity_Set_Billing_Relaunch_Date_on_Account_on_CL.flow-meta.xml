<?xml version="1.0" encoding="UTF-8"?>
<Flow xmlns="http://soap.sforce.com/2006/04/metadata">
    <apiVersion>53.0</apiVersion>
    <areMetricsLoggedToDataCloud>false</areMetricsLoggedToDataCloud>
    <decisions>
        <description>Checks what is the opportunity&apos;s record type.</description>
        <name>Opportunity_Record_Type</name>
        <label>Opportunity Record Type</label>
        <locationX>182</locationX>
        <locationY>323</locationY>
        <defaultConnector>
            <targetReference>Update_Account_Record</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>Billing Upsell</defaultConnectorLabel>
        <rules>
            <name>Experience_Curriculum</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>$Record.RecordTypeId</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>0123u000000BZUmAAO</stringValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Update_Account_Record_EC</targetReference>
            </connector>
            <label>Experience Curriculum</label>
        </rules>
    </decisions>
    <description>Sets Billing Relaunch Date field on account when Billing Opportunity is Closed Lost
07/26/2023 - PE - Updated the flow to include the same process for Experience Curriculum opportunities (Sprint 13 - 2023)</description>
    <environments>Default</environments>
    <interviewLabel>Opportunity - Set Billing Relaunch Date on Account on CL {!$Flow.CurrentDateTime}</interviewLabel>
    <label>Opportunity - Set Billing / EC Relaunch Date on Account on CL</label>
    <processMetadataValues>
        <name>BuilderType</name>
        <value>
            <stringValue>LightningFlowBuilder</stringValue>
        </value>
    </processMetadataValues>
    <processMetadataValues>
        <name>CanvasMode</name>
        <value>
            <stringValue>AUTO_LAYOUT_CANVAS</stringValue>
        </value>
    </processMetadataValues>
    <processMetadataValues>
        <name>OriginBuilderType</name>
        <value>
            <stringValue>LightningFlowBuilder</stringValue>
        </value>
    </processMetadataValues>
    <processType>AutoLaunchedFlow</processType>
    <recordUpdates>
        <description>Updates the field Billing Upsell Relaunch Date on the account record</description>
        <name>Update_Account_Record</name>
        <label>Update Account Record</label>
        <locationX>314</locationX>
        <locationY>431</locationY>
        <filterLogic>and</filterLogic>
        <filters>
            <field>Id</field>
            <operator>EqualTo</operator>
            <value>
                <elementReference>$Record.AccountId</elementReference>
            </value>
        </filters>
        <inputAssignments>
            <field>Billing_Relaunch_Date__c</field>
            <value>
                <elementReference>$Record.Opportunity_Relaunch_Date__c</elementReference>
            </value>
        </inputAssignments>
        <object>Account</object>
    </recordUpdates>
    <recordUpdates>
        <description>Updates the field Experience Curriculum Relaunch Date on the account record</description>
        <name>Update_Account_Record_EC</name>
        <label>Update Account Record</label>
        <locationX>50</locationX>
        <locationY>431</locationY>
        <filterLogic>and</filterLogic>
        <filters>
            <field>Id</field>
            <operator>EqualTo</operator>
            <value>
                <elementReference>$Record.AccountId</elementReference>
            </value>
        </filters>
        <inputAssignments>
            <field>Experience_Curriculum_Relaunch_Date__c</field>
            <value>
                <elementReference>$Record.Opportunity_Relaunch_Date__c</elementReference>
            </value>
        </inputAssignments>
        <object>Account</object>
    </recordUpdates>
    <start>
        <locationX>56</locationX>
        <locationY>0</locationY>
        <connector>
            <targetReference>Opportunity_Record_Type</targetReference>
        </connector>
        <filterLogic>1 AND 3 AND (2 OR 4)</filterLogic>
        <filters>
            <field>StageName</field>
            <operator>EqualTo</operator>
            <value>
                <stringValue>Closed Lost</stringValue>
            </value>
        </filters>
        <filters>
            <field>RecordTypeId</field>
            <operator>EqualTo</operator>
            <value>
                <stringValue>0123u000000aNBlAAM</stringValue>
            </value>
        </filters>
        <filters>
            <field>Opportunity_Relaunch_Date__c</field>
            <operator>IsNull</operator>
            <value>
                <booleanValue>false</booleanValue>
            </value>
        </filters>
        <filters>
            <field>RecordTypeId</field>
            <operator>EqualTo</operator>
            <value>
                <stringValue>0123u000000BZUmAAO</stringValue>
            </value>
        </filters>
        <object>Opportunity</object>
        <recordTriggerType>Update</recordTriggerType>
        <triggerType>RecordAfterSave</triggerType>
    </start>
    <status>Active</status>
</Flow>
