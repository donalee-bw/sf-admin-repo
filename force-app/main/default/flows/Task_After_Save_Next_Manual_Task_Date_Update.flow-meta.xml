    <decisions>
        <description>Checks if any future manually created record associated with the lead/contact was found</description>
        <name>Future_Task_Found</name>
        <label>Future Task Found?</label>
        <locationX>660</locationX>
        <locationY>792</locationY>
        <defaultConnector>
            <targetReference>Update_Field_on_Lead_or_Contact</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>No</defaultConnectorLabel>
        <rules>
            <name>Yes_Future_Task_Found</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>Get_Future_Tasks.Id</leftValueReference>
                <operator>IsNull</operator>
                <rightValue>
                    <booleanValue>false</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>New_Task_Due_Date_Before_Future_Task</targetReference>
            </connector>
            <label>Yes</label>
        </rules>
    </decisions>
    <decisions>
        <description>Checks if the newly created task&apos;s due date is before any existing future task.</description>
        <name>New_Task_Due_Date_Before_Future_Task</name>
        <label>New Task Due Date Before Future Task?</label>
        <locationX>484</locationX>
        <locationY>900</locationY>
        <defaultConnectorLabel>No</defaultConnectorLabel>
        <rules>
            <name>Yes_New_Task_Due_Date_Before_Future_Task</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>$Record.ActivityDate</leftValueReference>
                <operator>LessThan</operator>
                <rightValue>
                    <elementReference>Get_Future_Tasks.ActivityDate</elementReference>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Update_Field_on_Lead_or_Contact</targetReference>
            </connector>
            <label>Yes</label>
        </rules>
    </decisions>
    <decisions>
        <description>Checks if the field &quot;Next Manual Task Date&quot; either on the contact or lead associated with the task is null.</description>
        <name>Next_Manual_Task_Date_Field_Empty</name>
        <label>Next Manual Task Date Field Empty?</label>
        <locationX>440</locationX>
        <locationY>576</locationY>
        <defaultConnector>
            <targetReference>Get_Future_Tasks</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>No</defaultConnectorLabel>
        <rules>
            <name>Yes_Next_Manual_Task_Date_Field_Empty</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>Get_Lead_Record.Next_Manual_Task_Date__c</leftValueReference>
                <operator>IsNull</operator>
                <rightValue>
                    <booleanValue>true</booleanValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>Get_Contact_Record.Next_Manual_Task_Date__c</leftValueReference>
                <operator>IsNull</operator>
                <rightValue>
                    <booleanValue>true</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Update_Field_on_Lead_or_Contact</targetReference>
            </connector>
            <label>Yes</label>
        </rules>
    </decisions>
    <decisions>
        <description>Checks if the newly created task record is associated with a lead or a contact.</description>
        <name>Task_Associated_With_Lead_Or_Contact</name>
        <label>Task Associated With Lead Or Contact?</label>
        <locationX>440</locationX>
        <locationY>276</locationY>
        <defaultConnectorLabel>Default Outcome</defaultConnectorLabel>
        <rules>
            <name>Lead_Task_Associated_With_Lead_Or_Contact</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>$Record.WhoId</leftValueReference>
                <operator>StartsWith</operator>
                <rightValue>
                    <stringValue>00Q</stringValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Get_Lead_Record</targetReference>
            </connector>
            <label>Lead</label>
        </rules>
        <rules>
            <name>Contact_Task_Associated_With_Lead_Or_Contact</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>$Record.WhoId</leftValueReference>
                <operator>StartsWith</operator>
                <rightValue>
                    <stringValue>003</stringValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Get_Contact_Record</targetReference>
            </connector>
            <label>Contact</label>
        </rules>
    </decisions>
    <decisions>
        <description>Stamps the task due date on the &quot;Next Manual Task Date&quot; field on the related contact or lead.</description>
        <name>Update_Field_on_Lead_or_Contact</name>
        <label>Update Field on Lead or Contact</label>
        <locationX>440</locationX>
        <locationY>1368</locationY>
        <defaultConnector>
            <targetReference>Lead_Stamp_Task_Due_Date</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>Lead</defaultConnectorLabel>
        <rules>
            <name>Contact_Update_Field_on_Lead_or_Contact</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>Contact_Task_Associated_With_Lead_Or_Contact</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <booleanValue>true</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Contact_Stamp_Task_Due_Date</targetReference>
            </connector>
            <label>Contact</label>
        </rules>
    </decisions>
    <description>PE - Updates the field &quot;Next Manual Task Date&quot; with a task&apos;s due date on the contact / lead if a manual task is created by a rep
JH 10/2/24- Updated the entry criteria to reference sequence identifier for custom metadata tasks
BW 10/4/24 - Updated the batch size on the 10 min path to be 6.  We were receiving flow issues of updating more than 12 in a batch.</description>
    <environments>Default</environments>
    <formulas>
        <name>forD_Today</name>
        <dataType>Date</dataType>
        <expression>TODAY()</expression>
