        <filterFormula>AND(
  TEXT({!$Record.Cadence_Label__c}) = &quot;Core Onboarding - OBS &amp; GOBS&quot;,
  OR(
    /* SaaS Activation Funnel Stage changed TO Activated */
    AND(
      ISCHANGED({!$Record.SaaS_Activation_Funnel_Stage_2024__c}),
      TEXT({!$Record.SaaS_Activation_Funnel_Stage_2024__c}) = &quot;Activated&quot;
    ),

    /* Billing Activation Funnel Stage changed TO Activated */
    AND(
      ISCHANGED({!$Record.Billing_Activation_Funnel_Stage_2024__c}),
      TEXT({!$Record.Billing_Activation_Funnel_Stage_2024__c}) = &quot;Activated&quot;
    ),

    /* New Case Type changed TO Cancel Request */
    AND(
      ISCHANGED({!$Record.New_Case_Type__c}),
      TEXT({!$Record.New_Case_Type__c}) = &quot;Cancel Request&quot;
    )
  )
)</filterFormula>
