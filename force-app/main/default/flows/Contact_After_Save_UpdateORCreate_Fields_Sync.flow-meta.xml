    <decisions>
        <name>Update_Combined_Funnel_1</name>
        <label>Update Combined Funnel</label>
        <locationX>314</locationX>
        <locationY>323</locationY>
        <defaultConnectorLabel>No</defaultConnectorLabel>
        <rules>
            <name>Yes_UpdateCombinedFunnel</name>
            <conditionLogic>or</conditionLogic>
            <conditions>
                <leftValueReference>$Record.Declined_Billing_Training__c</leftValueReference>
                <operator>IsChanged</operator>
                <rightValue>
                    <booleanValue>true</booleanValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.Declined_SaaS_Training__c</leftValueReference>
                <operator>IsChanged</operator>
                <rightValue>
                    <booleanValue>true</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Get_Combined_Funnel</targetReference>
            </connector>
            <label>Yes</label>
        </rules>
    </decisions>
    <description>PE - Flow created to keep fields on the Contact in sync with their counterpart on other objects. (Revenue.io Implementation Project)</description>
    <environments>Default</environments>
    <formulas>
        <name>forB_CombinedFunnel_DeclinedBillingTrainig</name>
        <dataType>Boolean</dataType>
        <expression>IF(
ISCHANGED({!$Record.Declined_Billing_Training__c}),
{!$Record.Declined_Billing_Training__c},
{!Loop_on_Combined_Funnels.Declined_Billing_Training__c}
)</expression>
    </formulas>
    <formulas>
        <name>forB_CombinedFunnel_DeclinedSaaSTraining</name>
        <dataType>Boolean</dataType>
        <expression>IF(
ISCHANGED({!$Record.Declined_SaaS_Training__c}),
{!$Record.Declined_SaaS_Training__c},
{!Loop_on_Combined_Funnels.Declined_SaaS_Training__c}
)</expression>
    </formulas>
    <interviewLabel>Contact - After Save - UpdateORCreate - Fields Sync {!$Flow.CurrentDateTime}</interviewLabel>
