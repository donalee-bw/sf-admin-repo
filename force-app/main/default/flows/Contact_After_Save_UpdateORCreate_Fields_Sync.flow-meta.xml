    </recordUpdates>
    <start>
        <locationX>188</locationX>
        <locationY>0</locationY>
        <connector>
            <targetReference>Update_Combined_Funnel_1</targetReference>
        </connector>
        <filterLogic>(1 OR 2) AND (5 OR 6) AND (3 OR 4)</filterLogic>
        <filters>
            <field>Declined_SaaS_Training__c</field>
            <operator>IsChanged</operator>
            <value>
                <booleanValue>true</booleanValue>
            </value>
        </filters>
        <filters>
            <field>Declined_Billing_Training__c</field>
            <operator>IsChanged</operator>
