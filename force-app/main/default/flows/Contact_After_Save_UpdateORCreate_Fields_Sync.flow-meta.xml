    <recordLookups>
        <description>Get Combined Funnels where the triggering record is either the SaaS or Billing Primary Contact.</description>
        <name>Get_Combined_Funnel</name>
        <label>Get Combined Funnel</label>
        <locationX>50</locationX>
        <locationY>431</locationY>
        <assignNullValuesIfNoRecordsFound>false</assignNullValuesIfNoRecordsFound>
        <connector>
            <targetReference>Loop_on_Combined_Funnels</targetReference>
        </connector>
        <filterLogic>or</filterLogic>
        <filters>
            <field>SaaS_Primary_Contact__c</field>
            <operator>EqualTo</operator>
            <value>
                <elementReference>$Record.Id</elementReference>
            </value>
        </filters>
        <filters>
            <field>Billing_Primary_Contact__c</field>
            <operator>EqualTo</operator>
            <value>
                <elementReference>$Record.Id</elementReference>
            </value>
        </filters>
        <getFirstRecordOnly>false</getFirstRecordOnly>
        <object>Combined_Funnel__c</object>
        <queriedFields>Id</queriedFields>
        <queriedFields>Declined_Billing_Training__c</queriedFields>
        <queriedFields>Declined_SaaS_Training__c</queriedFields>
        <storeOutputAutomatically>true</storeOutputAutomatically>
    </recordLookups>
    <recordUpdates>
        <description>Updates the Combined Funnel records in the Collecition after the loop finishes.</description>
        <name>Update_Combined_Funnels</name>
        <label>Update Combined Funnels</label>
        <locationX>50</locationX>
        <locationY>947</locationY>
        <faultConnector>
            <targetReference>Flow_Error</targetReference>
        </faultConnector>
