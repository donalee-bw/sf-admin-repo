    </formulas>
    <formulas>
        <name>formOrgMatchingResult</name>
        <dataType>String</dataType>
        <expression>IF(AND(NOT(ISBLANK({!Get_Matching_Org.Outbound_Phone__c})),
             {!Get_Matching_Org.Normalized_Phone_Length__c}&gt;9,
            OR({!Get_Matching_Org.Outbound_Phone__c}={!Get_Lead_Record.Phone},
                  {!Get_Matching_Org.Outbound_Phone__c}={!Get_Lead_Record.MobilePhone},
                  {!Get_Matching_Org.Outbound_Phone__c}={!Get_Lead_Record.Normalized_Phone_10_Digits__c},
                  {!Get_Matching_Org.Normalized_Phone_10_Digits__c}={!Get_Lead_Record.Normalized_Phone_10_Digits__c})),
         &quot;Matched on Phone&quot;,
IF(AND(NOT(ISBLANK({!Get_Matching_Org.Website__c})),
            NOT(ISBLANK({!Get_Lead_Record.Website})),
           {!Get_Matching_Org.Website__c}={!Get_Lead_Record.Website}),
         &quot;Matched on Website&quot;,&quot;Matched on Email Domain&quot;))</expression>
    </formulas>
    <formulas>
        <name>formOrgMatchLocationMatch</name>
        <dataType>String</dataType>
        <expression>{!formOrgMatchingResult} &amp; &quot;;Location  Found&quot;</expression>
    </formulas>
    <formulas>
        <name>formOrgMatchNewLocation</name>
        <dataType>String</dataType>
        <expression>{!formOrgMatchingResult} &amp; &quot;;New Location&quot;</expression>
    </formulas>
    <formulas>
        <name>formOrgMatchPrimaryLocation</name>
        <dataType>String</dataType>
        <expression>{!formOrgMatchingResult} &amp; &quot;; Linked to Primary Location&quot;</expression>
    </formulas>
    <formulas>
        <name>NewLocationNameUpdated</name>
        <dataType>String</dataType>
        <expression>LEFT({!Get_Lead_Record.Company} + &quot; - &quot; + {!Get_Lead_Record.City}, 80)</expression>
    </formulas>
    <formulas>
        <name>trimOrgName</name>
        <dataType>String</dataType>
        <expression>LEFT({!Get_Lead_Record.Company},80)</expression>
    </formulas>
