                <rightValue>
                    <numberValue>1.0</numberValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Add_1_to_Due_Date_sunday</targetReference>
            </connector>
            <label>Assigned Date = Sunday</label>
        </rules>
        <rules>
            <name>Assigned_Date_Holiday</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>varHolidayDateCollectionText</leftValueReference>
                <operator>Contains</operator>
                <rightValue>
                    <elementReference>formCurrentTaskDueDateText</elementReference>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Add_1_to_Due_Date_holiday</targetReference>
            </connector>
            <label>Assigned Date = Holiday</label>
        </rules>
    </decisions>
