    <description>Pass sequence identifier (string from custom metadata Custom_Sequence__mdt.Sequence_Identifier__c), ContactId (who to associate tasks to), OnboardingId (which onboarding to associate tasks to) in order to generate a sequence</description>
    <environments>Default</environments>
    <formulas>
        <name>formCalculatedDueDate</name>
        <dataType>Date</dataType>
        <expression>today()+{!Loop_Sequence_Events.Sequence_Order__c} + {!varSequenceDelayNumber}</expression>
    </formulas>
    <formulas>
        <name>formCurrentTaskDueDateText</name>
        <dataType>String</dataType>
        <expression>TEXT( {!varTaskHolder.ActivityDate} )</expression>
    </formulas>
    <formulas>
        <name>formHolidayDateText</name>
        <dataType>String</dataType>
        <expression>TEXT( {!Loop_Holidays.Holiday_Date__c} )</expression>
    </formulas>
    <formulas>
        <description>dynamically</description>
        <name>formOwner</name>
        <dataType>String</dataType>
        <expression>&apos;Get_Contact.&apos; &amp; &apos;Loop_Sequence_Events.Owner__c&apos; &amp; &apos;&apos;</expression>
    </formulas>
    <formulas>
        <name>formOwnerIdDynamic</name>
        <dataType>String</dataType>
        <expression>&apos;Get_Contact.&apos; &amp; &apos;Loop_Sequence_Events.Owner__c&apos; &amp; &apos;&apos;</expression>
    </formulas>
    <formulas>
        <description>Include the Sequence Identifier in all of the subjects so the sequence assigned is more readily identified from the UI</description>
        <name>formSubject</name>
        <dataType>String</dataType>
        <expression> {!Loop_Sequence_Events.Subject__c} + &quot;: &quot; + TEXT({!Loop_Sequence_Events.Sequence_Identifier__c})</expression>
    </formulas>
    <formulas>
        <name>formWeekend</name>
        <dataType>Number</dataType>
        <expression>Weekday( {!varTaskHolder.ActivityDate} )</expression>
        <scale>0</scale>
    </formulas>
    <formulas>
        <name>forT18DigitId</name>
        <dataType>String</dataType>
        <expression>casesafeid({!Get_Contact.Id})</expression>
    </formulas>
