    <decisions>
        <name>Holiday_or_Weekend</name>
        <label>Holiday or Weekend</label>
        <locationX>534</locationX>
        <locationY>1490</locationY>
        <defaultConnector>
            <targetReference>Assign_New_Due_Date</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>Default Outcome</defaultConnectorLabel>
        <rules>
            <name>Assigned_Date_Saturday</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>formWeekend</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <numberValue>7.0</numberValue>
                </rightValue>
            </conditions>
            <connector>
