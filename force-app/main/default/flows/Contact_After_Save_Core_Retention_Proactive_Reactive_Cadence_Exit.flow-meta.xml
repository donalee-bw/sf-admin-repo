        <locationY>0</locationY>
        <connector>
            <targetReference>Get_Active_Cadence_Tracker</targetReference>
        </connector>
        <filterFormula>AND ( 
          TEXT({!$Record.Cadence_Label__c}) = &quot;Core Retention - Proactive &amp; Reactive&quot; ,
