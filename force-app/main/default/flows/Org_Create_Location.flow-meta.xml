    <description>Creates a Location record when an Organization record is created / updates and is not associated with any Location</description>
    <environments>Default</environments>
    <formulas>
        <description>Formula that checks if fields street, city, state, zip code, and country are filled out in the related account record.</description>
        <name>FormulaAccountFullAddress</name>
        <dataType>Boolean</dataType>
        <expression>AND(
    NOT(ISBLANK({!Get_Accounts.BillingStreet})),
    NOT(ISBLANK({!Get_Accounts.BillingCity})),
    NOT(ISBLANK({!Get_Accounts.BillingState})),
    NOT(ISBLANK({!Get_Accounts.BillingPostalCode})),
    NOT(ISBLANK({!Get_Accounts.BillingCountry}))
)</expression>
    </formulas>
    <formulas>
        <description>Formula that checks if all fields, street, city, state, zip code, and country are filled out in the related contact record.</description>
        <name>FormulaContactFullAddress</name>
        <dataType>String</dataType>
        <expression>IF(
    AND(
        NOT(ISBLANK({!currentItem_Filter_Contacts_With_Full_Address.MailingStreet})),
        NOT(ISBLANK({!Loop_Through_Contacts.MailingCity})),
        NOT(ISBLANK({!Loop_Through_Contacts.MailingState})),
        NOT(ISBLANK({!Loop_Through_Contacts.MailingPostalCode})),
        NOT(ISBLANK({!Loop_Through_Contacts.MailingCountry}))
    ),
    &quot;Yes&quot;,
    &quot;No&quot;
)</expression>
    </formulas>
    <formulas>
        <description>Formula that checks if all fields, street, city, state, zip code, and country are filled out in the related lead record.</description>
        <name>FormulaLeadFullAddress</name>
        <dataType>String</dataType>
        <expression>IF(
    AND(
        NOT(ISBLANK({!Loop_Through_Leads.Street})),
        NOT(ISBLANK({!Loop_Through_Leads.City})),
        NOT(ISBLANK({!Loop_Through_Leads.State})),
        NOT(ISBLANK({!Loop_Through_Leads.PostalCode})),
        NOT(ISBLANK({!Loop_Through_Leads.Country}))
    ),
    &quot;Yes&quot;,
    &quot;No&quot;
)</expression>
    </formulas>
    <formulas>
        <description>Formula looks if the related Account has the Capacity field populated. If it does, it transfers that value to the newly created location record. If it doesn&apos;t, it captures the highest value found in that field in the contacts associated with that organization. If there are no contacts associated, then it does the same for the lead records.</description>
        <name>FormulaLeadsHighestCapacity</name>
        <dataType>Number</dataType>
        <expression>IF(
    NOT(ISNULL({!Get_Accounts.Capacity__c})),
    {!Get_Accounts.Capacity__c},
    IF(
        NOT(ISNULL({!Loop_Through_Contacts.Id})),
        IF(
            {!Loop_Through_Contacts.Capacity__c} &gt; {!varLeadsHighestCapacity},
            {!Loop_Through_Contacts.Capacity__c},
            IF(
                {!Loop_Through_Leads.Capacity__c} &gt; {!varLeadsHighestCapacity},
                {!Loop_Through_Leads.Capacity__c},
                {!varLeadsHighestCapacity}
            )
        ),
        IF(
            {!Loop_Through_Leads.Capacity__c} &gt; {!varLeadsHighestCapacity},
            {!Loop_Through_Leads.Capacity__c},
            {!varLeadsHighestCapacity}
        )
    )
)</expression>
        <scale>0</scale>
    </formulas>
    <formulas>
        <name>varNormalizedSchoolName</name>
        <dataType>String</dataType>
        <expression>LEFT({!$Record.Normalized_School_Name__c},80)</expression>
    </formulas>
