    <decisions>
        <description>Checks if the data on the field &quot;Next Manual Task Date&quot; is today. If it is, the flow will either wipe out the value or update it.</description>
        <name>Next_Manual_Task_Date_Due_Today</name>
        <label>Next Manual Task Date Due Today?</label>
        <locationX>380</locationX>
        <locationY>252</locationY>
        <defaultConnectorLabel>No</defaultConnectorLabel>
        <rules>
            <name>Yes_Next_Manual_Task_Date_Due_Today</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>$Record.Next_Manual_Task_Date__c</leftValueReference>
                <operator>LessThanOrEqualTo</operator>
                <rightValue>
                    <elementReference>$Flow.CurrentDate</elementReference>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Get_Future_Tasks</targetReference>
            </connector>
            <label>Yes</label>
        </rules>
    </decisions>
    <description>PE - Checks all lead records with a date on the &quot;Next Manual Task Date&quot; field and wipes it out if that date is equal to or less than today. If there&apos;s another manually created task associated with that lead record, update the field with that task&apos;s due date.</description>
