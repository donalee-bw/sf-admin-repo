<?xml version="1.0" encoding="UTF-8"?>
<Flow xmlns="http://soap.sforce.com/2006/04/metadata">
    <apiVersion>60.0</apiVersion>
    <areMetricsLoggedToDataCloud>false</areMetricsLoggedToDataCloud>
    <decisions>
        <description>Identifies if the Case has an Account</description>
        <name>Found_Account</name>
        <label>Found Account?</label>
        <locationX>776</locationX>
        <locationY>431</locationY>
        <defaultConnectorLabel>Default Outcome</defaultConnectorLabel>
        <rules>
            <name>Has_Account</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>$Record.Account.Id</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <elementReference>Get_Account_Fields.Id</elementReference>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Update_Fields</targetReference>
            </connector>
            <label>Has Account</label>
        </rules>
    </decisions>
    <decisions>
        <name>Update_Fields</name>
        <label>Update Fields</label>
        <locationX>446</locationX>
        <locationY>539</locationY>
        <defaultConnectorLabel>Default Outcome</defaultConnectorLabel>
        <rules>
            <name>Newest_Cancel_Case</name>
            <conditionLogic>or</conditionLogic>
            <conditions>
                <leftValueReference>$Record.Status</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>New</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.Status</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Assigned</stringValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Update_Account_Days_Since_Saved</targetReference>
            </connector>
            <label>Newest Cancel Case</label>
        </rules>
        <rules>
            <name>Saved_Cancel_Case_Status</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>$Record.Status</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Saved</stringValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Update_Acct_Date_Cancel_Case_Saved</targetReference>
            </connector>
            <label>Saved Cancel Case Status</label>
        </rules>
        <rules>
            <name>Saved_Cancel_Case</name>
            <conditionLogic>or</conditionLogic>
            <conditions>
                <leftValueReference>$Record.Status</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Canceled</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.Status</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Auto Closed</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.Status</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Closed</stringValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Update_Account_Most_Recent_Cancel_Status</targetReference>
            </connector>
            <label>Closed Cancel Case</label>
        </rules>
    </decisions>
    <description>Updates Date Cancel Closed and Most Recent Closed Cancel Case stage based on the most recent case status. Sprint 10. 5.4.24 JC</description>
    <environments>Default</environments>
    <formulas>
        <name>CalculateDaysSinceSaved</name>
        <dataType>Number</dataType>
        <expression>{!$Flow.CurrentDate}-{!Get_Account_Fields.Date_Cancel_Case_Saved__c}</expression>
        <scale>0</scale>
    </formulas>
    <formulas>
        <name>Saved_Date</name>
        <dataType>Date</dataType>
        <expression>Today()</expression>
    </formulas>
    <interviewLabel>Account - Calculate Cancel Case Dates {!$Flow.CurrentDateTime}</interviewLabel>
    <label>Account - Calculate Cancel Case Dates</label>
    <processMetadataValues>
        <name>BuilderType</name>
