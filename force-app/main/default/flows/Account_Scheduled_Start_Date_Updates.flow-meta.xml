    <description>Scheduled job to update SaaS Onboarding Start Date if Original Close Date is 14+ days ago and SaaS Onboarding Start Date is blank. Does the same for Billing Onboarding Start Date and the Billing Launch Date field

BW 6/14/24 - Swapped out old funnel values from CF to new Funnel Values on School Object</description>
    <environments>Default</environments>
    <formulas>
        <description>Calculated Date: Billing Launch Date + 14 days</description>
        <name>CalculatedBillingStartDate</name>
        <dataType>Date</dataType>
        <expression>{!$Record.Billing_Launch_Date__c} + 14</expression>
    </formulas>
    <formulas>
        <description>Calculated date: Original Close Date + 14 days</description>
        <name>CalculatedSaaSStartDate</name>
        <dataType>Date</dataType>
        <expression>{!$Record.Original_Close_Date__c} + 14</expression>
    </formulas>
    <formulas>
        <description>Stores the threshold to make an account potentially eligible for a start date update</description>
        <name>StartDateThreshold</name>
        <dataType>Date</dataType>
        <expression>TODAY() - 14</expression>
    </formulas>
