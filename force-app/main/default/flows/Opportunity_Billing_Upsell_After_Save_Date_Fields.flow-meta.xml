    <description>Flow to capture critical meeting dates, such as Billing Discovery Call Scheduled, Billing Discovery Call Completed, Billing Demo Call Scheduled, and Billing Demo Call Completed.
07/01/24 - PE - Updated flow to only get open opportunities.
10/16/24 - MC - Added Demo Call Set and Demo Call Scheduled to the completed assignments</description>
    <environments>Default</environments>
    <formulas>
        <name>forDDemoScheduled</name>
        <dataType>Date</dataType>
        <expression>IF( ISNULL( {!Get_Billing_Upsell_Opportunity.Demo_Call_Scheduled__c} ),  {!$Record.ActivityDate} ,
IF( ( {!Get_Billing_Upsell_Opportunity.Demo_Call_Scheduled__c} &gt;  {!$Record.ActivityDate} ),  {!$Record.ActivityDate} , {!Get_Billing_Upsell_Opportunity.Demo_Call_Scheduled__c}
)
)</expression>
    </formulas>
    <formulas>
        <name>forDDemoSet</name>
        <dataType>Date</dataType>
        <expression>IF( ISNULL( {!Get_Billing_Upsell_Opportunity.Demo_Call_Set__c} ), DATEVALUE( {!$Record.CreatedDate} ),
IF( ( {!Get_Billing_Upsell_Opportunity.Demo_Call_Set__c} &gt; DATEVALUE( {!$Record.CreatedDate} )),  DATEVALUE( {!$Record.CreatedDate} ), {!Get_Billing_Upsell_Opportunity.Demo_Call_Set__c})
)</expression>
    </formulas>
    <formulas>
