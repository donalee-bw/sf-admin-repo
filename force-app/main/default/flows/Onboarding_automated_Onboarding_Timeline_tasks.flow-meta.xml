    <decisions>
        <name>Onboarding_records</name>
        <label>Onboarding records</label>
        <locationX>231</locationX>
        <locationY>171</locationY>
        <defaultConnectorLabel>Default Outcome</defaultConnectorLabel>
        <rules>
            <name>Onboarding_record_found</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>Get_onboardings</leftValueReference>
                <operator>IsNull</operator>
                <rightValue>
                    <booleanValue>false</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Loop_onboardings</targetReference>
            </connector>
            <label>Onboarding record found</label>
        </rules>
    </decisions>
    <decisions>
        <name>Task_decision</name>
        <label>Task decision</label>
        <locationX>230</locationX>
        <locationY>511</locationY>
        <defaultConnectorLabel>Default Outcome</defaultConnectorLabel>
        <rules>
            <name>Add_roster_by_date</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>Loop_onboardings.Active_Student_Enrollment_Percent__c</leftValueReference>
                <operator>LessThan</operator>
                <rightValue>
                    <numberValue>90.0</numberValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>Loop_onboardings.Add_Roster_By__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <elementReference>day_after_due_date</elementReference>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Temp_add_roster_task</targetReference>
            </connector>
            <label>Add roster by date</label>
        </rules>
        <rules>
            <name>Invite_parents_by_date</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>Loop_onboardings.Active_Students_Parents_Activated__c</leftValueReference>
                <operator>LessThan</operator>
                <rightValue>
                    <numberValue>5.0</numberValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>Loop_onboardings.Invite_Parents_By__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <elementReference>day_after_due_date</elementReference>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>Loop_onboardings.Active_Students_Parents_Activated__c</leftValueReference>
                <operator>IsNull</operator>
                <rightValue>
                    <booleanValue>false</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Temp_invite_parents_task</targetReference>
            </connector>
            <label>Invite parents by date</label>
        </rules>
        <rules>
            <name>Confirmed_launch_date</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>Loop_onboardings.Confirmed_Launch_Date__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <elementReference>three_days_after_due_date</elementReference>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>Loop_onboardings.Last_Action_Date__c</leftValueReference>
                <operator>GreaterThanOrEqualTo</operator>
                <rightValue>
                    <elementReference>day_after_due_date</elementReference>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>Loop_onboardings.Active_Student_Action_Count__c</leftValueReference>
                <operator>LessThan</operator>
                <rightValue>
                    <elementReference>current_enrollment_times_three</elementReference>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Temp_confirmed_launch_date_task</targetReference>
            </connector>
            <label>Confirmed launch date</label>
        </rules>
    </decisions>
    <description>Flow to create automatic tasks on onboarding when items fall outside manual Onboarding Timeline date fields</description>
    <formulas>
        <name>current_enrollment_times_three</name>
        <dataType>Number</dataType>
        <expression>{!Loop_onboardings.Current_Enrollment__c} * 3</expression>
        <scale>0</scale>
    </formulas>
    <formulas>
        <name>day_after_due_date</name>
        <dataType>Date</dataType>
        <expression>TODAY() - 1</expression>
    </formulas>
    <formulas>
        <name>three_days_after_due_date</name>
        <dataType>Date</dataType>
        <expression>TODAY() - 3</expression>
    </formulas>
    <interviewLabel>Onboarding automated Onboarding Timeline tasks {!$Flow.CurrentDateTime}</interviewLabel>
    <label>Onboarding automated Onboarding Timeline tasks</label>
