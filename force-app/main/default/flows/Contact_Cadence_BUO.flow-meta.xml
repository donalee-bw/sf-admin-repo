            </value>
        </filters>
        <filters>
            <field>Declined_SaaS_Training__c</field>
            <operator>IsChanged</operator>
            <value>
                <booleanValue>true</booleanValue>
            </value>
        </filters>
        <filters>
            <field>SaaS_Activation_Funnel_Stage_2024__c</field>
            <operator>IsChanged</operator>
            <value>
                <booleanValue>true</booleanValue>
            </value>
        </filters>
        <filters>
            <field>Cadence_Tag__c</field>
            <operator>EqualTo</operator>
            <value>
                <stringValue>Remove</stringValue>
            </value>
        </filters>
        <filters>
            <field>Cadence_Tag__c</field>
            <operator>IsChanged</operator>
            <value>
                <booleanValue>true</booleanValue>
            </value>
        </filters>
        <filters>
            <field>Cadence_Label__c</field>
            <operator>EqualTo</operator>
