        <defaultConnectorLabel>Default Outcome</defaultConnectorLabel>
        <rules>
            <name>BW_Attach</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>$Record.Account__r.School_Object__r.Brightwheel_Plan__c</leftValueReference>
