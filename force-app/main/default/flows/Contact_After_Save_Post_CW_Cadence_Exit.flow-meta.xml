    <recordLookups>
        <name>Get_Active_Cadence_Tracker</name>
        <label>Get Active Cadence Tracker</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <assignNullValuesIfNoRecordsFound>false</assignNullValuesIfNoRecordsFound>
        <connector>
            <targetReference>Was_active_cadence_Tracker_Found</targetReference>
        </connector>
        <filterLogic>and</filterLogic>
        <filters>
            <field>TargetId</field>
            <operator>EqualTo</operator>
            <value>
                <elementReference>$Record.Id</elementReference>
            </value>
        </filters>
        <filters>
            <field>State</field>
            <operator>NotEqualTo</operator>
            <value>
                <stringValue>Completed</stringValue>
            </value>
        </filters>
        <getFirstRecordOnly>true</getFirstRecordOnly>
        <object>ActionCadenceStepTracker</object>
        <sortField>CreatedDate</sortField>
        <sortOrder>Desc</sortOrder>
        <storeOutputAutomatically>true</storeOutputAutomatically>
    </recordLookups>
    <recordUpdates>
        <name>SE_tag</name>
        <label>SE tag</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <inputAssignments>
            <field>SE_Tag__c</field>
            <value>
                <stringValue>Contact - After Save - Post CW Cadence Exit   - V1</stringValue>
            </value>
        </inputAssignments>
        <inputReference>$Record</inputReference>
    </recordUpdates>
    <start>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <connector>
            <targetReference>Get_Active_Cadence_Tracker</targetReference>
        </connector>
        <doesRequireRecordChangedToMeetCriteria>true</doesRequireRecordChangedToMeetCriteria>
        <filterFormula>AND(
        TEXT({!$Record.Cadence_Label__c}) = &quot;Sales - Missed Demo&quot; , 
    OR(
        {!$Record.Do_Not_Contact__c} = TRUE,
        {!$Record.LOGIC_Owned_by_queue__c} = TRUE,
        BEGINS(TEXT({!$Record.Most_Recent_Disposition__c}), &quot;REC - &quot;),
        BEGINS(TEXT({!$Record.Most_Recent_Disposition__c}), &quot;UNQ - &quot;),
        BEGINS(TEXT({!$Record.Most_Recent_Disposition__c}), &quot;CC - &quot;),
         BEGINS(TEXT({!$Record.Most_Recent_Disposition__c}), &quot;PD - &quot;),
       CONTAINS(TEXT({!$Record.Most_Recent_Disposition__c}), &quot;Rescheduled&quot;),
   
        BEGINS({!$Record.Outreach_stage__c}, &quot;Recycled &quot;),
        BEGINS({!$Record.Outreach_stage__c}, &quot;Unqualified&quot;),
        BEGINS({!$Record.Outreach_stage__c}, &quot;Connected&quot;),
        BEGINS(TEXT({!$Record.Manual_Stage_Update__c}), &quot;Recycled &quot;),
        BEGINS(TEXT({!$Record.Manual_Stage_Update__c}), &quot;Unqualified&quot;),
        BEGINS(TEXT({!$Record.Manual_Stage_Update__c}), &quot;Connected&quot;)
        
    )
)</filterFormula>
        <object>Contact</object>
        <recordTriggerType>Update</recordTriggerType>
        <triggerType>RecordAfterSave</triggerType>
    </start>
    <status>Active</status>
</Flow>
