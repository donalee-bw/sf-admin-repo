    <decisions>
        <name>Evaluate_Disposition</name>
        <label>Evaluate Disposition</label>
        <locationX>314</locationX>
        <locationY>492</locationY>
        <defaultConnectorLabel>No Update</defaultConnectorLabel>
        <rules>
            <name>Spoke_to_DM</name>
            <conditionLogic>or</conditionLogic>
            <conditions>
                <leftValueReference>$Record.Disposition__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>NA - Spoke to DM (Did Not Pitch)</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.Disposition__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>EDU - Spoke to DM did not pitch</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.Disposition__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Cancel - Spoke to DM / Did Not Pitch</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.Disposition__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Proactive - Spoke to DM / Did Not Pitch</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.Disposition__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Billing - Spoke to DM / Did Not Pitch</stringValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Lead_DM_Update</targetReference>
            </connector>
            <label>Spoke to DM</label>
        </rules>
        <rules>
            <name>Spoke_to_Non_DM</name>
            <conditionLogic>or</conditionLogic>
            <conditions>
                <leftValueReference>$Record.Disposition__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>NA - Spoke to Non-DM (GK Navigation)</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.Disposition__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>OBS - Spoke to Non-DM / Sent Info</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.Disposition__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>EN - Spoke to Non-DM / Sent Info</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.Disposition__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>EDU - Y, Spoke to non DM</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.Disposition__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Cancel - Spoke to Non DM</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.Disposition__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Proactive - Spoke to Non DM</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.Disposition__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Billing - Spoke to Non DM</stringValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Lead_Non_DM_Update</targetReference>
            </connector>
            <label>Spoke to Non-DM</label>
        </rules>
    </decisions>
