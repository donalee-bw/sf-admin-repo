    <decisions>
        <name>Check_for_all_The_decisions</name>
        <label>Check for all The decisions</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <defaultConnector>
            <targetReference>Route_to_agent_with_no_screen_pop</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>Default Outcome</defaultConnectorLabel>
        <rules>
            <name>Case_Found</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>Search_Records_by_Phone.caseId</leftValueReference>
                <operator>IsNull</operator>
                <rightValue>
                    <booleanValue>false</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Pop_Screen_With_Case</targetReference>
            </connector>
            <label>Case Found</label>
        </rules>
        <rules>
            <name>If_contact_is_found</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>Search_Records_by_Phone.caseId</leftValueReference>
                <operator>IsNull</operator>
                <rightValue>
                    <booleanValue>true</booleanValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>Search_Records_by_Phone.contactId</leftValueReference>
                <operator>IsNull</operator>
                <rightValue>
                    <booleanValue>false</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Pop_Screen_With_Contact</targetReference>
            </connector>
            <label>If contact is found</label>
        </rules>
        <rules>
            <name>If_Account_is_found_but_contact_isnt</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>Search_Records_by_Phone.caseId</leftValueReference>
                <operator>IsNull</operator>
                <rightValue>
                    <booleanValue>true</booleanValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>Search_Records_by_Phone.contactId</leftValueReference>
                <operator>IsNull</operator>
                <rightValue>
                    <booleanValue>true</booleanValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>Search_Records_by_Phone.accountId</leftValueReference>
                <operator>IsNull</operator>
                <rightValue>
                    <booleanValue>false</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Pop_Screen_With_Account</targetReference>
            </connector>
            <label>If Account is found but contact isnt</label>
        </rules>
        <rules>
            <name>Lead_Found_But_not_contact_and_account</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>Search_Records_by_Phone.caseId</leftValueReference>
                <operator>IsNull</operator>
                <rightValue>
                    <booleanValue>true</booleanValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>Search_Records_by_Phone.contactId</leftValueReference>
                <operator>IsNull</operator>
                <rightValue>
                    <booleanValue>true</booleanValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>Search_Records_by_Phone.accountId</leftValueReference>
                <operator>IsNull</operator>
                <rightValue>
                    <booleanValue>true</booleanValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>Search_Records_by_Phone.leadId</leftValueReference>
                <operator>IsNull</operator>
                <rightValue>
                    <booleanValue>false</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Pop_Screen_With_Lead</targetReference>
            </connector>
            <label>Lead Found But not contact and account</label>
        </rules>
    </decisions>
    <description>this version include decision to check which case etc record found for routing</description>
    <environments>Default</environments>
    <formulas>
        <name>formattedNumLastTenDigits</name>
        <dataType>String</dataType>
        <expression>RIGHT(
  SUBSTITUTE(
    SUBSTITUTE(
      SUBSTITUTE(
            SUBSTITUTE({!customerNumber}, &apos;+1&apos;, &apos;&apos;),
      &quot; &quot;, &quot;&quot;),
    &quot;-&quot;, &quot;&quot;),
  &quot;(&quot;, &quot;&quot;),
10
)</expression>
    </formulas>
    <formulas>
        <name>formattedNumWithoutSpecialChars</name>
        <dataType>String</dataType>
        <expression>SUBSTITUTE(
  SUBSTITUTE(
    SUBSTITUTE(
      SUBSTITUTE(
        SUBSTITUTE(
        {!customerNumber},
          &quot; &quot;,
          &quot;&quot;
        ),
        &quot;(&quot;,
        &quot;&quot;
      ),
      &quot;)&quot;,
      &quot;&quot;
    ),
    &quot;-&quot;,
    &quot;&quot;
  ),
  &quot;+&quot;,
  &quot;&quot;
)</expression>
    </formulas>
