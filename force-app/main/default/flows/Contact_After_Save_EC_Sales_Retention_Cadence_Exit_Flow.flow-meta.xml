    <recordLookups>
        <description>** Testing with the Cadence Tracker Active ** vs the other builds we used, State != complete to see if that works better.</description>
        <name>Get_Active_Cadence_Tracker</name>
        <label>Get Active Cadence Tracker</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <assignNullValuesIfNoRecordsFound>false</assignNullValuesIfNoRecordsFound>
        <connector>
            <targetReference>Active_Cadence_Tracker_Found</targetReference>
        </connector>
        <filterLogic>and</filterLogic>
        <filters>
            <field>TargetId</field>
            <operator>EqualTo</operator>
            <value>
                <elementReference>$Record.Id</elementReference>
            </value>
        </filters>
        <filters>
            <field>IsTrackerActive</field>
            <operator>EqualTo</operator>
            <value>
                <booleanValue>true</booleanValue>
            </value>
        </filters>
        <getFirstRecordOnly>true</getFirstRecordOnly>
        <object>ActionCadenceTracker</object>
        <storeOutputAutomatically>true</storeOutputAutomatically>
    </recordLookups>
    <recordUpdates>
        <name>SE_Tag</name>
        <label>SE Tag</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <inputAssignments>
            <field>SE_Tag__c</field>
            <value>
                <stringValue>Contact - After Save - EC Sales/Retention Cadence Exit Flow  </stringValue>
            </value>
        </inputAssignments>
        <inputReference>$Record</inputReference>
    </recordUpdates>
    <start>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <connector>
            <targetReference>Get_Active_Cadence_Tracker</targetReference>
        </connector>
        <filterFormula>AND(
  OR(
    /*EC SALES */
    AND(
      OR(
        TEXT({!$Record.Cadence_Label__c}) = &quot;EC - Sales Starter&quot;,
        TEXT({!$Record.Cadence_Label__c}) = &quot;EC - Sales Missed Demo&quot;,
        TEXT({!$Record.Cadence_Label__c}) = &quot;EC - Sales Post Demo&quot;
      ),
      OR(
        {!$Record.Do_Not_Contact__c} = TRUE,
        TEXT({!$Record.New_Case_Type__c}) = &quot;Cancel Request&quot;,
        TEXT({!$Record.New_Case_Type__c}) = &quot;EC Cancel Request&quot;
      )
    ),

    /* EC Retention Starter – NEW logic */
    AND(
      TEXT({!$Record.Cadence_Label__c}) = &quot;EC - Retention Starter&quot;,
      OR(
        {!$Record.Do_Not_Contact__c} = TRUE,
        CONTAINS({!$Record.Most_Recent_Case_Status__c}, &quot;Saved&quot;),
        CONTAINS({!$Record.Most_Recent_Case_Status__c}, &quot;Canceled&quot;),
        CONTAINS({!$Record.Most_Recent_Case_Status__c}, &quot;Closed&quot;),
        CONTAINS({!$Record.Most_Recent_Case_Status__c}, &quot;Auto Closed&quot;)
      )
    )
  )
)</filterFormula>
        <object>Contact</object>
        <recordTriggerType>Update</recordTriggerType>
        <triggerType>RecordAfterSave</triggerType>
    </start>
    <status>Active</status>
</Flow>
