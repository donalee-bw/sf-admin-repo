<?xml version="1.0" encoding="UTF-8"?>
<Flow xmlns="http://soap.sforce.com/2006/04/metadata">
    <apiVersion>53.0</apiVersion>
    <areMetricsLoggedToDataCloud>false</areMetricsLoggedToDataCloud>
    <decisions>
        <name>Conversion_Validation</name>
        <label>Conversion Validation</label>
        <locationX>1040</locationX>
        <locationY>431</locationY>
        <defaultConnectorLabel>No Conversion</defaultConnectorLabel>
        <rules>
            <name>Conversion_Found_Recent_Update</name>
            <conditionLogic>1 AND (2 OR 3)</conditionLogic>
            <conditions>
                <leftValueReference>Get_HS_Conversion_Mapping</leftValueReference>
                <operator>IsNull</operator>
                <rightValue>
                    <booleanValue>false</booleanValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>RecentConversionDate</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <booleanValue>true</booleanValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>FreeTrialWithin4Days</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <booleanValue>true</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Get_Prior_HS_Conversion</targetReference>
            </connector>
            <label>Conversion Found, Recent Update</label>
        </rules>
        <rules>
            <name>Conversion_Found_No_Recent_Updates</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>Get_HS_Conversion_Mapping</leftValueReference>
                <operator>IsNull</operator>
                <rightValue>
                    <booleanValue>false</booleanValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>RecentConversionDate</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <booleanValue>false</booleanValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>FreeTrialWithin4Days</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <booleanValue>false</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Update_Inbound_Activity_on_Lead</targetReference>
            </connector>
            <label>Conversion Found, No Recent Updates</label>
        </rules>
        <rules>
            <name>No_Conversion_Free_Trial</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>Get_HS_Conversion_Mapping</leftValueReference>
                <operator>IsNull</operator>
                <rightValue>
                    <booleanValue>true</booleanValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>FreeTrialWithin4Days</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <booleanValue>true</booleanValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.Last_Inbound_Activity__c</leftValueReference>
                <operator>NotEqualTo</operator>
                <rightValue>
                    <stringValue>PTL</stringValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Update_to_PTL</targetReference>
            </connector>
            <label>No Conversion, Free Trial</label>
        </rules>
    </decisions>
    <decisions>
        <name>Priority_Ranking_Handler</name>
        <label>Priority Ranking Handler</label>
        <locationX>446</locationX>
        <locationY>671</locationY>
        <defaultConnectorLabel>No Update</defaultConnectorLabel>
        <rules>
            <name>Prior_Found_No_Free_Trial</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>Get_Prior_HS_Conversion</leftValueReference>
                <operator>IsNull</operator>
                <rightValue>
                    <booleanValue>false</booleanValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>FreeTrialWithin4Days</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <booleanValue>false</booleanValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>Get_HS_Conversion_Mapping.Priority_Ranking__c</leftValueReference>
                <operator>LessThanOrEqualTo</operator>
                <rightValue>
                    <elementReference>Get_Prior_HS_Conversion.Priority_Ranking__c</elementReference>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Update_Lead_with_New_Inbound_Activity</targetReference>
            </connector>
            <label>Prior Found, No Free Trial</label>
        </rules>
        <rules>
            <name>Prior_Found_Free_Trial</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>Get_Prior_HS_Conversion</leftValueReference>
                <operator>IsNull</operator>
                <rightValue>
                    <booleanValue>false</booleanValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>Get_HS_Conversion_Mapping.Priority_Ranking__c</leftValueReference>
                <operator>LessThanOrEqualTo</operator>
                <rightValue>
                    <numberValue>5.0</numberValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>FreeTrialWithin4Days</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <booleanValue>true</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <isGoTo>true</isGoTo>
                <targetReference>Update_Lead_with_New_Inbound_Activity</targetReference>
            </connector>
            <label>Prior Found, Free Trial</label>
        </rules>
        <rules>
            <name>No_Prior_Free_Trial</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>Get_Prior_HS_Conversion</leftValueReference>
                <operator>IsNull</operator>
                <rightValue>
                    <booleanValue>true</booleanValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>FreeTrialWithin4Days</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <booleanValue>true</booleanValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>Get_HS_Conversion_Mapping.Priority_Ranking__c</leftValueReference>
                <operator>LessThanOrEqualTo</operator>
                <rightValue>
                    <numberValue>5.0</numberValue>
                </rightValue>
            </conditions>
            <connector>
                <isGoTo>true</isGoTo>
                <targetReference>Update_Lead_with_New_Inbound_Activity</targetReference>
            </connector>
            <label>No Prior, Free Trial</label>
        </rules>
    </decisions>
    <description>When HS activity is triggered, evaluates if last inbound activity field needs to be updated</description>
    <formulas>
        <name>FreeTrialWithin4Days</name>
        <dataType>Boolean</dataType>
        <expression>DATEVALUE({!$Record.School_Object__r.CreatedDate}) &gt;= TODAY()-4</expression>
    </formulas>
    <formulas>
        <name>RecentConversionDate</name>
        <dataType>Boolean</dataType>
        <expression>DATEVALUE({!$Record__Prior.HS_Recent_conversion_date__c}) &gt;= Today()-4</expression>
    </formulas>
    <interviewLabel>Lead - Last Inbound Activity on Update {!$Flow.CurrentDateTime}</interviewLabel>
    <label>Lead - Last Inbound Activity on Update</label>
    <processMetadataValues>
        <name>BuilderType</name>
        <value>
            <stringValue>LightningFlowBuilder</stringValue>
        </value>
    </processMetadataValues>
    <processMetadataValues>
        <name>CanvasMode</name>
        <value>
            <stringValue>AUTO_LAYOUT_CANVAS</stringValue>
        </value>
    </processMetadataValues>
    <processMetadataValues>
        <name>OriginBuilderType</name>
        <value>
            <stringValue>LightningFlowBuilder</stringValue>
        </value>
    </processMetadataValues>
    <processType>AutoLaunchedFlow</processType>
