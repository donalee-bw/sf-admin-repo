        <filters>
            <field>HS_Recent_Convers__c</field>
            <operator>EqualTo</operator>
            <value>
                <elementReference>$Record__Prior.HS_Recent_conversion__c</elementReference>
            </value>
        </filters>
        <getFirstRecordOnly>true</getFirstRecordOnly>
        <object>HS_Conversion_Mapping__c</object>
        <queriedFields>Id</queriedFields>
        <queriedFields>Sales_Conversion_Type__c</queriedFields>
