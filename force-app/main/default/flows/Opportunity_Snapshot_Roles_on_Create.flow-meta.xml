    <decisions>
        <description>Checks if the account found meets the criteria of the previous get element</description>
        <name>Correct_Account_Found</name>
        <label>Correct Account Found</label>
        <locationX>182</locationX>
        <locationY>600</locationY>
        <defaultConnector>
            <targetReference>Get_Open_Events</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>No</defaultConnectorLabel>
        <rules>
            <name>Yes_Account_Found</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>Get_Account.Id</leftValueReference>
                <operator>IsNull</operator>
                <rightValue>
                    <booleanValue>false</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Update_Capacity_on_Account_From_Opp</targetReference>
            </connector>
            <label>Yes</label>
        </rules>
    </decisions>
    <decisions>
        <name>Found_Opp_Account_decision</name>
        <label>Found Opp Account decision</label>
        <locationX>1172</locationX>
        <locationY>384</locationY>
        <defaultConnectorLabel>Default Outcome</defaultConnectorLabel>
        <rules>
            <name>Found_Opp_Account</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>Get_Opp_Account.Id</leftValueReference>
                <operator>IsNull</operator>
                <rightValue>
                    <booleanValue>false</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Needs_Education_Owner_Assignment</targetReference>
            </connector>
            <label>Found Opp Account</label>
        </rules>
    </decisions>
    <decisions>
        <description>If this a new Experience Curriculum opportunity create on an account that doesn&apos;t have an active Education Owner, then launch Account Assigments Subflow</description>
        <name>Needs_Education_Owner_Assignment</name>
        <label>Needs Education Owner Assignment?</label>
        <locationX>974</locationX>
        <locationY>492</locationY>
        <defaultConnectorLabel>Default Outcome</defaultConnectorLabel>
        <rules>
            <name>Yes_Needs_Education_Owner_Assignment</name>
            <conditionLogic>(1 OR 3) AND 2</conditionLogic>
            <conditions>
                <leftValueReference>Get_Opp_Account.Education_Owner__r.IsActive</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <booleanValue>false</booleanValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.Opportunity_Record_Type__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Experience Curriculum</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>Get_Opp_Account.Education_Owner__c</leftValueReference>
                <operator>IsNull</operator>
                <rightValue>
                    <booleanValue>true</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Launch_Account_Assignment</targetReference>
            </connector>
            <label>Yes</label>
        </rules>
    </decisions>
    <decisions>
        <name>Open_Events_Found</name>
        <label>Open Events Found</label>
        <locationX>182</locationX>
        <locationY>1008</locationY>
        <defaultConnectorLabel>No</defaultConnectorLabel>
        <rules>
            <name>Yes_OpenEventFound</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>Get_Open_Events</leftValueReference>
                <operator>IsNull</operator>
                <rightValue>
                    <booleanValue>false</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Loop_On_Events</targetReference>
            </connector>
            <label>Yes</label>
        </rules>
    </decisions>
    <decisions>
        <name>SaaS_Opp</name>
        <label>SaaS Opp</label>
        <locationX>380</locationX>
        <locationY>384</locationY>
        <defaultConnectorLabel>Default Outcome</defaultConnectorLabel>
        <rules>
            <name>Yes_SaaS</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>$Record.RecordTypeId</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>0123u000000aNBgAAM</stringValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Get_Account</targetReference>
            </connector>
            <label>Yes SaaS</label>
        </rules>
    </decisions>
    <description>06/15/2023 - Add elements to identify open events associated with the opportunity&apos;s account and populates the &apos;Related To&apos; field with the new opportunity. (Sprint 10)
03/28/24 - PE - Added subflow to scheduled path to call Account Assignments
03/28/25 - BW - Added Qualified By to be populated by CreatedBy id and Role</description>
    <environments>Default</environments>
    <interviewLabel>Opportunity - Snapshot Roles on Create {!$Flow.CurrentDateTime}</interviewLabel>
    <label>Opp - Snapshot Roles on Create / Update Account Capacity  &amp; Events</label>
    <loops>
        <name>Loop_On_Events</name>
        <label>Loop On Events</label>
        <locationX>50</locationX>
        <locationY>1116</locationY>
        <collectionReference>Get_Open_Events</collectionReference>
        <iterationOrder>Asc</iterationOrder>
        <nextValueConnector>
            <targetReference>Set_Oppty_for_the_Event</targetReference>
        </nextValueConnector>
        <noMoreValuesConnector>
            <targetReference>Update_Events</targetReference>
        </noMoreValuesConnector>
    </loops>
    <processMetadataValues>
