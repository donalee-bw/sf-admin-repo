    <recordUpdates>
        <name>Update_Capacity_on_Account_From_Opp</name>
        <label>Update Capacity on Account From Opp</label>
        <locationX>50</locationX>
        <locationY>708</locationY>
        <connector>
            <targetReference>Get_Open_Events</targetReference>
        </connector>
        <filterLogic>and</filterLogic>
        <filters>
            <field>Id</field>
            <operator>EqualTo</operator>
            <value>
                <elementReference>Get_Account.Id</elementReference>
            </value>
        </filters>
        <inputAssignments>
            <field>Capacity__c</field>
            <value>
                <elementReference>$Record.Capacity__c</elementReference>
            </value>
        </inputAssignments>
        <object>Account</object>
    </recordUpdates>
    <recordUpdates>
        <description>To update the event records in the collection after loop finishes</description>
        <name>Update_Events</name>
        <label>Update Events</label>
        <locationX>50</locationX>
        <locationY>1524</locationY>
        <inputReference>EventsToBeUpdatedCollection</inputReference>
    </recordUpdates>
    <start>
        <locationX>650</locationX>
        <locationY>0</locationY>
        <connector>
            <targetReference>Populate_Snapshot_Fields</targetReference>
        </connector>
        <object>Opportunity</object>
