        <connector>
            <targetReference>Get_Failed_Payment_case</targetReference>
        </connector>
        <filterFormula>OR(
  AND(
    {!$Record.Stripe_Status__c} = &quot;failed&quot;,
    ISNEW()
  ),
  AND(
    ISCHANGED( {!$Record.Stripe_Status__c} ),
    {!$Record.Stripe_Status__c} = &quot;failed&quot;
  )
)</filterFormula>
