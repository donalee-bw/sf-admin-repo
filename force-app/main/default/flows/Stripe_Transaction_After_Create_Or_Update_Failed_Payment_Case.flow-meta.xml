    <description>BW - 09/27/24 - Added check for open Cancel Request Cases.  If found, we do not create a FP case
JH - 1/27/25 - updated to ensure account ID is set to account from get contact or get school object using matching stripe customer email from stripe transaction</description>
    <environments>Default</environments>
    <formulas>
        <name>forAccountID</name>
        <dataType>String</dataType>
        <expression>IF(
  {!varAccountId} &lt;&gt; NULL,
  {!varAccountId},
IF(
  {!varSchoolAccountId} &lt;&gt; NULL,
  {!varSchoolAccountId}, 
 IF(
    {!varContactAccountID} &lt;&gt; NULL,
    {!varContactAccountID},
    &quot;&quot;
  )
)
)</expression>
    </formulas>
    <formulas>
        <name>forContactID</name>
        <dataType>String</dataType>
        <expression>  IF(
    {!varContactId} &lt;&gt; NULL,
    {!varContactId},
    &quot;&quot;
  )</expression>
    </formulas>
    <formulas>
        <name>formulaStripeBrand</name>
        <dataType>String</dataType>
        <expression>IF( LEFT( {!$Record.Stripe_Charge_Type__c}, 3) = &quot;ch_&quot;, {!$Record.Stripe_Funding__c}, &quot;ACH Account&quot;)</expression>
    </formulas>
    <formulas>
        <name>formulaStripeFunding</name>
        <dataType>String</dataType>
        <expression>IF( LEFT( {!$Record.Stripe_Charge_Type__c}, 3) = &quot;ch_&quot;, {!$Record.Stripe_Brand__c}, &quot;ACH Account&quot;)</expression>
    </formulas>
