                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.Troops_HS_return_path_trigger__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <booleanValue>true</booleanValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.LOGIC_Open_HS_task__c</leftValueReference>
                <operator>GreaterThan</operator>
                <rightValue>
                    <numberValue>0.0</numberValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.Troops_PTL_return_path_trigger__c</leftValueReference>
