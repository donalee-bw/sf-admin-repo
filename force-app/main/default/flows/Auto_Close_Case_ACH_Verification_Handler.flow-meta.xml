<?xml version="1.0" encoding="UTF-8"?>
<Flow xmlns="http://soap.sforce.com/2006/04/metadata">
    <apiVersion>53.0</apiVersion>
    <areMetricsLoggedToDataCloud>false</areMetricsLoggedToDataCloud>
    <decisions>
        <description>Checks if the related account has an active user assigned on the field SaaS Owner</description>
        <name>Account_Has_SaaS_Owner</name>
        <label>Account Has SaaS Owner?</label>
        <locationX>930</locationX>
        <locationY>708</locationY>
        <defaultConnector>
            <targetReference>Launch_Account_Assignment</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>No</defaultConnectorLabel>
        <rules>
            <name>Yes_Account_Has_SaaS_Owner</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>$Record.Account.SaaS_Owner__r.IsActive</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <booleanValue>true</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Assign_Ownership_to_SaaS_Owner</targetReference>
            </connector>
            <label>Yes</label>
        </rules>
    </decisions>
    <decisions>
        <name>ACH_Status_Verified</name>
        <label>ACH Status Verified</label>
        <locationX>996</locationX>
        <locationY>276</locationY>
        <defaultConnector>
            <targetReference>Get_Account</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>Non Verified</defaultConnectorLabel>
        <rules>
            <name>Verified</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>$Record.Stripe_ACH_Status__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Verified</stringValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Auto_Close_ACH_Verified</targetReference>
            </connector>
            <label>Verified</label>
        </rules>
    </decisions>
    <decisions>
        <name>Determine_Target_Status</name>
        <label>Determine Target Status</label>
        <locationX>1414</locationX>
        <locationY>492</locationY>
        <defaultConnector>
            <targetReference>Auto_Close_Non_Premium_Target</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>Non Premium Target</defaultConnectorLabel>
        <rules>
            <name>Premium_Target</name>
            <conditionLogic>2 AND (1 OR 3)</conditionLogic>
            <conditions>
                <leftValueReference>$Record.Account.Current_Premium_ECE__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <booleanValue>true</booleanValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.Account.Customer_Segment__c</leftValueReference>
                <operator>NotEqualTo</operator>
                <rightValue>
                    <stringValue>Micro</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.Account.Ever_Premium_ECE__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <booleanValue>true</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>New_Case_Record</targetReference>
            </connector>
            <label>Premium Target</label>
        </rules>
        <rules>
            <name>No_Related_Account</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>$Record.Account.Id</leftValueReference>
                <operator>IsNull</operator>
                <rightValue>
                    <booleanValue>true</booleanValue>
                </rightValue>
            </conditions>
            <label>No Related Account</label>
        </rules>
    </decisions>
    <decisions>
        <name>Duplicate_ACH_Case</name>
        <label>Duplicate ACH Case</label>
        <locationX>182</locationX>
        <locationY>384</locationY>
        <defaultConnectorLabel>No New Case Exists</defaultConnectorLabel>
        <rules>
            <name>Another_New_Case_Exists</name>
            <conditionLogic>or</conditionLogic>
            <conditions>
                <leftValueReference>Get_Other_New_ACH_Cases</leftValueReference>
                <operator>IsNull</operator>
                <rightValue>
                    <booleanValue>false</booleanValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>Get_Other_New_ACH_Cases.CreatedDate</leftValueReference>
                <operator>GreaterThanOrEqualTo</operator>
                <rightValue>
                    <elementReference>$Flow.CurrentDate</elementReference>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Auto_Close_Existing_New_Case</targetReference>
            </connector>
            <label>Another New Case Exists</label>
        </rules>
    </decisions>
    <decisions>
        <description>Checks if the case record was just created</description>
        <name>New_Case_Record</name>
        <label>New Case Record?</label>
        <locationX>1106</locationX>
        <locationY>600</locationY>
        <defaultConnector>
            <targetReference>Set_ACH_Distribution_Type</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>No</defaultConnectorLabel>
        <rules>
            <name>Yes_NewCaseRecord</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>forB_IsNew</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <booleanValue>true</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Account_Has_SaaS_Owner</targetReference>
            </connector>
            <label>Yes</label>
        </rules>
    </decisions>
    <description>Auto Closes cases that are duplicated on the same day, tied to Non Premium Target customers, or if the ACH status is already verified.  The Auto Close process delays by 72 hours to allow processing of the ACH status
12/20/23 - Updated record ownership assignment to RR between user on Failed Payment group
03/20/24 - PE - Updated ownership assignment to account&apos;s SaaS Owner user to to round robin it if no user is found.</description>
    <environments>Default</environments>
    <formulas>
        <name>forB_IsNew</name>
        <dataType>Boolean</dataType>
        <expression>ISNEW()</expression>
    </formulas>
    <interviewLabel>Auto Close Case - ACH Verification Handler {!$Flow.CurrentDateTime}</interviewLabel>
    <label>Auto Close Case - ACH Verification Handler</label>
    <processMetadataValues>
