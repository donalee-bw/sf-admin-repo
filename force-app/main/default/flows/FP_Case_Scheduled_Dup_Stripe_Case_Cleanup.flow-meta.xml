            <label>Yes</label>
        </rules>
    </decisions>
    <decisions>
        <description>compares the value of the Stripe Invoice ID held in var_CurrentInvoiceID with the value of the Stripe Invoice ID from the current case in the loop. 
The default of this variable is null so the first time it runs, it should get sent down the new invoice ID path.</description>
        <name>Check_if_Invoice_ID_Changed</name>
        <label>Check if Invoice ID Changed</label>
        <locationX>270</locationX>
        <locationY>684</locationY>
        <defaultConnector>
            <targetReference>Assign_CurrentInvoice_ID2</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>New Invoice ID</defaultConnectorLabel>
        <rules>
            <name>Same_Invoice_ID</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>var_CurrentInvoiceID</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <elementReference>Loop_cases_and_group_by_InvoiceID.Stripe_invoice_ID__c</elementReference>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Assign_CurrentInvoice_ID</targetReference>
            </connector>
            <label>Same Invoice ID (Has Dup)</label>
        </rules>
    </decisions>
    <description>JH - Scheduled flow that looks for failed payment cases created today and closes out the duplicate cases. Considered a duplicate if the Stripe invoice ID is the same. There should only be 1 open FP case per invoice ID.</description>
    <environments>Default</environments>
    <interviewLabel>Failed Payment Case {!$Flow.CurrentDateTime}</interviewLabel>
    <label>FP Case - Scheduled - Dup Stripe Case Cleanup</label>
    <loops>
