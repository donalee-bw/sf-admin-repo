    <recordLookups>
        <name>Get_FP_Cases_Created_Today</name>
        <label>Get FP Cases Created Today</label>
        <locationX>182</locationX>
        <locationY>252</locationY>
        <assignNullValuesIfNoRecordsFound>true</assignNullValuesIfNoRecordsFound>
        <connector>
