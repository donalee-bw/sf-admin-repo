        <label>Loop cases and group by InvoiceID</label>
        <locationX>50</locationX>
        <locationY>576</locationY>
        <collectionReference>col_FailedPaymentCases</collectionReference>
        <iterationOrder>Asc</iterationOrder>
        <nextValueConnector>
            <targetReference>Check_if_Invoice_ID_Changed</targetReference>
        </nextValueConnector>
        <noMoreValuesConnector>
            <targetReference>Update_Dup_Cases_Collection</targetReference>
        </noMoreValuesConnector>
    </loops>
