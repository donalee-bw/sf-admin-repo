        <filterLogic>and</filterLogic>
        <filters>
            <field>Stripe_invoice_ID__c</field>
            <operator>IsNull</operator>
            <value>
                <booleanValue>false</booleanValue>
            </value>
        </filters>
        <filters>
            <field>RecordTypeId</field>
            <operator>EqualTo</operator>
            <value>
                <stringValue>0121I000000ODmUQAW</stringValue>
            </value>
        </filters>
        <filters>
            <field>IsClosed</field>
            <operator>NotEqualTo</operator>
            <value>
                <booleanValue>true</booleanValue>
            </value>
        </filters>
        <filters>
            <field>Origin</field>
            <operator>EqualTo</operator>
            <value>
                <stringValue>Stripe</stringValue>
            </value>
        </filters>
        <filters>
            <field>Days_Since_Created_Date__c</field>
            <operator>LessThan</operator>
            <value>
                <numberValue>1.0</numberValue>
            </value>
        </filters>
        <object>Case</object>
        <outputReference>col_FailedPaymentCases</outputReference>
        <queriedFields>Id</queriedFields>
        <queriedFields>Stripe_attempt_count__c</queriedFields>
        <queriedFields>Status</queriedFields>
        <queriedFields>Description</queriedFields>
        <queriedFields>Stripe_invoice_ID__c</queriedFields>
        <sortField>Stripe_invoice_ID__c</sortField>
        <sortOrder>Desc</sortOrder>
    </recordLookups>
