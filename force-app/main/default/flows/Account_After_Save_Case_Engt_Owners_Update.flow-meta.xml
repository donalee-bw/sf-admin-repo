<?xml version="1.0" encoding="UTF-8"?>
<Flow xmlns="http://soap.sforce.com/2006/04/metadata">
    <apiVersion>60.0</apiVersion>
    <areMetricsLoggedToDataCloud>false</areMetricsLoggedToDataCloud>
    <assignments>
        <description>Assigns the updated SaaS / BU Owner users to the fields Engt Delegation Owner and SaaS Delegation Owner on the contact.</description>
        <name>Assign_SaaS_and_BUO_Delegation_Owners</name>
        <label>Assign SaaS and BUO Delegation Owners</label>
        <locationX>704</locationX>
        <locationY>708</locationY>
        <assignmentItems>
            <assignToReference>varR_UniqueContact.SaaS_Delegation_Owner__c</assignToReference>
            <operator>Assign</operator>
            <value>
                <elementReference>$Record.SaaS_Owner__c</elementReference>
            </value>
        </assignmentItems>
        <assignmentItems>
            <assignToReference>varR_UniqueContact.Engt_Delegation_Owner__c</assignToReference>
            <operator>Assign</operator>
            <value>
                <elementReference>$Record.Billing_Upsell_Owner__c</elementReference>
            </value>
        </assignmentItems>
        <assignmentItems>
            <assignToReference>varR_UniqueContact.Id</assignToReference>
            <operator>Assign</operator>
            <value>
                <elementReference>Loop_Through_Cases.ContactId</elementReference>
            </value>
        </assignmentItems>
        <assignmentItems>
            <assignToReference>varR_ContactsToUpdate</assignToReference>
            <operator>Add</operator>
            <value>
                <elementReference>varR_UniqueContact</elementReference>
            </value>
        </assignmentItems>
        <connector>
            <targetReference>Loop_Through_Cases</targetReference>
        </connector>
    </assignments>
    <assignments>
        <description>Gets the id of the contact associated with the case.</description>
        <name>Get_Case_s_Contact_Id</name>
        <label>Get Case&apos;s Contact Id</label>
        <locationX>616</locationX>
        <locationY>492</locationY>
        <assignmentItems>
            <assignToReference>varR_UniqueContact.Contact_ID__c</assignToReference>
            <operator>Assign</operator>
            <value>
                <elementReference>Loop_Through_Cases.ContactId</elementReference>
            </value>
        </assignmentItems>
        <connector>
            <targetReference>Duplicated_Contact</targetReference>
        </connector>
    </assignments>
    <decisions>
        <description>Checks if the current contact was already captured when looping through another flow.</description>
        <name>Duplicated_Contact</name>
        <label>Duplicated Contact?</label>
        <locationX>616</locationX>
        <locationY>600</locationY>
        <defaultConnector>
            <targetReference>Assign_SaaS_and_BUO_Delegation_Owners</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>No</defaultConnectorLabel>
        <rules>
            <name>Yes_Duplicated_Contact</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>varR_ContactsToUpdate</leftValueReference>
                <operator>Contains</operator>
                <rightValue>
                    <elementReference>varR_UniqueContact</elementReference>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Loop_Through_Cases</targetReference>
            </connector>
            <label>Yes</label>
        </rules>
    </decisions>
    <decisions>
        <name>Found_Contacts_To_Be_Updated</name>
        <label>Found Contacts To Be Updated?</label>
        <locationX>440</locationX>
        <locationY>984</locationY>
        <defaultConnectorLabel>No</defaultConnectorLabel>
        <rules>
            <name>Yes_Found_Contacts_To_Be_Updated</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>varR_ContactsToUpdate</leftValueReference>
                <operator>IsNull</operator>
                <rightValue>
                    <booleanValue>false</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Update_All_Contacts</targetReference>
            </connector>
            <label>Yes</label>
        </rules>
    </decisions>
    <description>If the users set on the field SaaS Owner or Billing Upsell owners are updated at the account level, we mirror the new user to all contacts associated with any open case on the account, populating the fields Engt Delegation Owner and SaaS Delegation Owner.</description>
    <environments>Default</environments>
    <interviewLabel>Account - Record {!$Flow.CurrentDateTime}</interviewLabel>
    <label>Account - After Save - Case Engt Owners Update</label>
    <loops>
        <name>Loop_Through_Cases</name>
        <label>Loop Through Cases</label>
        <locationX>440</locationX>
        <locationY>384</locationY>
        <collectionReference>Get_Open_Cases</collectionReference>
        <iterationOrder>Asc</iterationOrder>
        <nextValueConnector>
            <targetReference>Get_Case_s_Contact_Id</targetReference>
        </nextValueConnector>
        <noMoreValuesConnector>
            <targetReference>Found_Contacts_To_Be_Updated</targetReference>
        </noMoreValuesConnector>
    </loops>
    <processMetadataValues>
        <name>BuilderType</name>
        <value>
            <stringValue>LightningFlowBuilder</stringValue>
        </value>
    </processMetadataValues>
    <processMetadataValues>
        <name>CanvasMode</name>
        <value>
            <stringValue>AUTO_LAYOUT_CANVAS</stringValue>
        </value>
    </processMetadataValues>
    <processMetadataValues>
        <name>OriginBuilderType</name>
        <value>
            <stringValue>LightningFlowBuilder</stringValue>
        </value>
    </processMetadataValues>
    <processType>AutoLaunchedFlow</processType>
    <recordLookups>
        <description>Get open cases associated with account</description>
        <name>Get_Open_Cases</name>
        <label>Get Open Cases</label>
        <locationX>440</locationX>
        <locationY>276</locationY>
        <assignNullValuesIfNoRecordsFound>false</assignNullValuesIfNoRecordsFound>
        <connector>
            <targetReference>Loop_Through_Cases</targetReference>
        </connector>
        <filterLogic>and</filterLogic>
        <filters>
            <field>AccountId</field>
            <operator>EqualTo</operator>
            <value>
                <elementReference>$Record.Id</elementReference>
            </value>
        </filters>
        <filters>
            <field>IsClosed</field>
            <operator>EqualTo</operator>
            <value>
                <booleanValue>false</booleanValue>
            </value>
        </filters>
        <filters>
            <field>ContactId</field>
            <operator>IsNull</operator>
            <value>
                <booleanValue>false</booleanValue>
            </value>
        </filters>
        <getFirstRecordOnly>false</getFirstRecordOnly>
        <object>Case</object>
        <storeOutputAutomatically>true</storeOutputAutomatically>
    </recordLookups>
    <recordUpdates>
        <name>Update_All_Contacts</name>
        <label>Update All Contacts</label>
        <locationX>308</locationX>
        <locationY>1092</locationY>
        <inputReference>varR_ContactsToUpdate</inputReference>
    </recordUpdates>
    <start>
        <locationX>50</locationX>
        <locationY>0</locationY>
        <filterLogic>1 AND (2 OR 3)</filterLogic>
        <filters>
            <field>Total_Number_of_Open_Cases__c</field>
            <operator>GreaterThan</operator>
            <value>
                <numberValue>0.0</numberValue>
            </value>
        </filters>
        <filters>
            <field>SaaS_Owner__c</field>
            <operator>IsChanged</operator>
            <value>
                <booleanValue>true</booleanValue>
            </value>
        </filters>
        <filters>
            <field>Billing_Upsell_Owner__c</field>
            <operator>IsChanged</operator>
            <value>
                <booleanValue>true</booleanValue>
            </value>
        </filters>
        <object>Account</object>
        <recordTriggerType>Update</recordTriggerType>
        <scheduledPaths>
            <connector>
                <targetReference>Get_Open_Cases</targetReference>
            </connector>
            <pathType>AsyncAfterCommit</pathType>
        </scheduledPaths>
        <triggerType>RecordAfterSave</triggerType>
    </start>
    <status>Active</status>
    <variables>
        <name>varR_ContactsToUpdate</name>
        <dataType>SObject</dataType>
        <isCollection>true</isCollection>
        <isInput>false</isInput>
        <isOutput>false</isOutput>
        <objectType>Contact</objectType>
    </variables>
    <variables>
        <name>varR_UniqueContact</name>
        <dataType>SObject</dataType>
        <isCollection>false</isCollection>
        <isInput>false</isInput>
        <isOutput>false</isOutput>
        <objectType>Contact</objectType>
    </variables>
</Flow>
