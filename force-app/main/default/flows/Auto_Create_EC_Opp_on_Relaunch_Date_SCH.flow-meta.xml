    <description>Scheduled flow that runs when Experience Curriculum Relaunch Date.
JH 8/1/24: updated to run every day at 7PM PST instead of 1AM PST</description>
    <environments>Default</environments>
    <formulas>
        <description>sets the &apos;Close Date&apos; of the new EC opportunity to be 30 days from the current date.</description>
        <name>CloseDateIn30Days</name>
        <dataType>Date</dataType>
        <expression>{!$Flow.CurrentDate} + 30</expression>
    </formulas>
    <formulas>
        <description>Returns true if the owner on the latest created Experience Curriculum opportunity is still active in Salesforce.</description>
        <name>LatestECOpportunityOwnerIsActive</name>
        <dataType>Boolean</dataType>
        <expression>{!Get_Last_EC_Opportunity.Owner.IsActive} = True</expression>
    </formulas>
    <formulas>
        <description>Created the new Experience Curriculum opportunity name based on logic</description>
        <name>NewECOpportunityName</name>
        <dataType>String</dataType>
        <expression>{!$Record.Name} &amp; &quot; - Experience Curriculum &quot; &amp; TEXT(MONTH(TODAY())) &amp; &quot;/&quot; &amp; TEXT(YEAR(TODAY()))</expression>
    </formulas>
    <formulas>
        <description>Checks if the Opportunity&apos;s Close Date is within the next 60 days.</description>
        <name>OpportunityCloseDateWithin60Days</name>
        <dataType>Boolean</dataType>
        <expression>{!Get_Latest_CW_Opportunity.CloseDate} - TODAY() &lt; 60</expression>
    </formulas>
