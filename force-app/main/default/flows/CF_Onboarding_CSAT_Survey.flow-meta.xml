    <decisions>
        <description>Determines if the CSAT survey has been sent before, and if it was at least 60 days ago if so.</description>
        <name>Ready_to_Send_Survey_0_0</name>
        <label>Ready to Send Survey</label>
        <locationX>182</locationX>
        <locationY>539</locationY>
        <defaultConnectorLabel>Default Outcome</defaultConnectorLabel>
        <rules>
            <name>Survey_Not_Yet_Sent_0_0</name>
            <conditionLogic>1 AND (2 OR 3 OR 4)</conditionLogic>
            <conditions>
                <leftValueReference>$Record.CSAT_Survey_First_Sent__c</leftValueReference>
                <operator>IsChanged</operator>
                <rightValue>
                    <booleanValue>true</booleanValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record__Prior.CSAT_Survey_First_Sent__c</leftValueReference>
                <operator>LessThanOrEqualTo</operator>
                <rightValue>
                    <elementReference>saasActivationDateThreshold</elementReference>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.CSAT_Survey_First_Sent__c</leftValueReference>
                <operator>IsNull</operator>
                <rightValue>
                    <booleanValue>true</booleanValue>
