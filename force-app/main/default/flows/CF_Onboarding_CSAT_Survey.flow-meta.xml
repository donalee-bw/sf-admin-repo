            </conditions>
            <conditions>
                <leftValueReference>$Record__Prior.CSAT_Survey_First_Sent__c</leftValueReference>
                <operator>IsNull</operator>
                <rightValue>
                    <booleanValue>true</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Send_CSAT_Survey</targetReference>
            </connector>
            <label>Survey Not Yet Sent</label>
        </rules>
    </decisions>
    <description>Secondary Flow triggered off CF update that sends CSAT Survey. Primary flow triggered off School Object is called: School - Send CSAT Email. 
JH 7/8/25 - Updated to remove exclusion of BNP onboarding path accounts AND replace the condition &apos;billing launch date&apos; = null with &apos;billing activation start date&apos; = null</description>
    <environments>Default</environments>
    <formulas>
        <description>Returns a date of 60 days prior to the current date. 
Used when checking if a billing survey for a previously activated SaaS customer should be sent</description>
        <name>saasActivationDateThreshold</name>
        <dataType>Date</dataType>
        <expression>TODAY() - 60</expression>
    </formulas>
