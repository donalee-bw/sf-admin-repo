    <decisions>
        <name>Was_Combined_Funnel_Found</name>
        <label>Was Combined Funnel Found?</label>
        <locationX>776</locationX>
        <locationY>431</locationY>
        <defaultConnectorLabel>Default Outcome</defaultConnectorLabel>
        <rules>
            <name>Yes_CF_Found</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>Get_Combined_Funnel</leftValueReference>
                <operator>IsNull</operator>
                <rightValue>
                    <booleanValue>false</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>What_is_the_Closed_Status</targetReference>
            </connector>
            <label>Yes,CF Found</label>
        </rules>
    </decisions>
    <decisions>
        <description>The closed status of the Passback to Sales - Billing at Risk will determine the updates.</description>
        <name>What_is_the_Closed_Status</name>
        <label>What is the Closed Status?</label>
        <locationX>446</locationX>
        <locationY>539</locationY>
        <defaultConnectorLabel>Default Outcome</defaultConnectorLabel>
        <rules>
            <name>Closed_Resumed_Onboarding</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>$Record.Status</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Closed: Customer Resumed OB</stringValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Update_Billing_Onboarding_Status_to_Active_on_CF</targetReference>
            </connector>
            <label>Closed : Resumed Onboarding</label>
        </rules>
        <rules>
            <name>Closed_Unresponsive</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>$Record.Status</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Closed: Customer Unresponsive</stringValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Update_Billing_Onboarding_Status_on_CF</targetReference>
            </connector>
            <label>Closed : Unresponsive</label>
        </rules>
        <rules>
            <name>Closed_Opted_Out</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>$Record.Status</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Closed: Opted Out</stringValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Update_Billing_Onboarding_Status_Billing_Opted_on_CF</targetReference>
            </connector>
            <label>Closed: Opted Out</label>
        </rules>
    </decisions>
    <decisions>
        <description>Billing Upsell Opp does not follow the SSPR Path.</description>
        <name>What_type_of_Opportunity</name>
        <label>What type of Opportunity</label>
        <locationX>446</locationX>
        <locationY>947</locationY>
        <defaultConnector>
            <targetReference>Sub_Flow_to_Update_Opportunity_Post_CW_Status</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>Default Outcome</defaultConnectorLabel>
        <rules>
            <name>Billing_Upsell</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>$Record.Opportunity__r.Opportunity_Record_Type__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Billing Upsell</stringValue>
                </rightValue>
            </conditions>
            <label>Billing Upsell</label>
        </rules>
    </decisions>
    <description>When AE closes out the Billing at Risk case, updates to the Combined Funnel and Opportunity needs to made. 
