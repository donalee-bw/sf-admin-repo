    <areMetricsLoggedToDataCloud>false</areMetricsLoggedToDataCloud>
    <decisions>
        <name>Stripe_Payment_Pending</name>
        <label>Stripe Payment Pending?</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <defaultConnectorLabel>Default Outcome</defaultConnectorLabel>
        <rules>
            <name>Yes_Pending_Payment</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>$Record.Status</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Stripe - Pending Payment</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>Get_Account.Hubspot_Suppression__c</leftValueReference>
                <operator>IsNull</operator>
                <rightValue>
                    <booleanValue>true</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Update_Hubspot_Suppression</targetReference>
            </connector>
            <label>Yes, Pending Payment</label>
        </rules>
        <rules>
            <name>Previous_Pending_Payment</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>$Record.Status</leftValueReference>
                <operator>NotEqualTo</operator>
                <rightValue>
                    <stringValue>Stripe - Pending Payment</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>Get_Account.Hubspot_Suppression__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Gov Transfer Stripe Pending Payment</stringValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Remove_Hubspot_Suppression</targetReference>
            </connector>
            <label>Previous Pending Payment</label>
        </rules>
    </decisions>
    <environments>Default</environments>
    <interviewLabel>Case - After Save - {!$Flow.CurrentDateTime}</interviewLabel>
    <label>Case - After Save - Gov Transfer Stripe Payment Pending</label>
