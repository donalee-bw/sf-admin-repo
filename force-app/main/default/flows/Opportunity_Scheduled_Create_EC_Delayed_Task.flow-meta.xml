            </connector>
            <label>Yes</label>
        </rules>
    </decisions>
    <description>When the opportunity is in the Delayed Start stage and the Curriculum Start Month field is filled in, the flow will create a task on the 1st of that month with a due date set for the 5th.</description>
    <environments>Default</environments>
    <formulas>
        <name>forB_CurriculumStartsNextMonth</name>
        <dataType>Boolean</dataType>
        <expression>MONTH({!$Record.Curriculum_Start_Month__c}) = MONTH(ADDMONTHS(TODAY(), 1)) &amp;&amp;
YEAR({!$Record.Curriculum_Start_Month__c}) = YEAR(ADDMONTHS(TODAY(), 1))</expression>
    </formulas>
    <formulas>
        <name>forB_IsFirstDayOfMonth</name>
        <dataType>Boolean</dataType>
        <expression>DAY(TODAY()) = 1</expression>
    </formulas>
    <formulas>
        <name>forD_CurrentMonth5th</name>
        <dataType>Date</dataType>
        <expression>DATE(YEAR(TODAY()), MONTH(TODAY()), 5)</expression>
    </formulas>
