        <description>Checks if today is the first day of the month and if the date in the Curriculum Start Month field falls within the current month.</description>
        <name>Check_First_Day_Curriculum_Month</name>
        <label>Check: First Day &amp; Curriculum Month</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <defaultConnectorLabel>No</defaultConnectorLabel>
        <rules>
