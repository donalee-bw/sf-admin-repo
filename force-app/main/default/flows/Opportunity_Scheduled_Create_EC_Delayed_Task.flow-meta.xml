            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>forB_CurriculumStartsNextMonth</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <booleanValue>true</booleanValue>
                </rightValue>
            </conditions>
            <conditions>
