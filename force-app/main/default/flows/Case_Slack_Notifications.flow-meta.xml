                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Cancelation_Request</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.RecordType.DeveloperName</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Failed_Payment</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>IsNewFormula</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <booleanValue>true</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Notify_CF_Owner_NewCase</targetReference>
            </connector>
            <label>New Case</label>
        </rules>
        <rules>
            <name>Status_Canceled</name>
            <conditionLogic>2 AND (1 OR 3)</conditionLogic>
            <conditions>
                <leftValueReference>$Record.RecordType.DeveloperName</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Cancelation_Request</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.Status</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Canceled</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.RecordType.DeveloperName</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Failed_Payment</stringValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Notify_CF_Owner_CanceledStatus</targetReference>
            </connector>
            <label>Status = Canceled</label>
        </rules>
        <rules>
            <name>Status_Saved</name>
            <conditionLogic>2 AND (1 OR 3)</conditionLogic>
            <conditions>
                <leftValueReference>$Record.RecordType.DeveloperName</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Cancelation_Request</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.Status</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Saved</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.RecordType.DeveloperName</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Failed_Payment</stringValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Notify_CF_Owner_SavedStatus</targetReference>
            </connector>
            <label>Status = Saved</label>
        </rules>
    </decisions>
    <description>Flow that sends Slack notifications to combined funnel owners when specific case types are created or updated. 
04/12/2023 - Updated the flow to not ping when SaaS Activated and Billing is Opted Out and/or no ‘Billing Launch Date’ (Sprint 6 - 2023)
02/06/24 - Added action to notify user upon case ownership change.</description>
    <environments>Default</environments>
    <formulas>
        <name>forT_SlackAlertTemplate</name>
        <dataType>String</dataType>
        <expression>&apos;You have been assigned a &apos; &amp;
IF(
     {!$Record.RecordTypeId} = &apos;0121I000000ODmUQAW&apos;, 
     &apos;Failed Payment&apos;, 
      IF(
           {!$Record.RecordTypeId} = &apos;0123u000000aN7yAAE&apos;, 
           &apos;Cancelation Request&apos;, 
            &apos;&apos;
       )
) &amp;
&apos; Case&apos; &amp;
SUBSTITUTE($Label.NewLine , &quot;-&quot;, &quot;&quot;)  &amp;
&apos;&lt;https://brightwheel1.my.salesforce.com/&apos; &amp; {!$Record.Id}  &amp; &apos;|[View in Salesforce]&gt;&apos; &amp;
SUBSTITUTE($Label.NewLine , &quot;-&quot;, &quot;&quot;)  &amp;
&apos;*Account Name:* &apos; &amp; {!$Record.Account.Name}  &amp;
SUBSTITUTE($Label.NewLine , &quot;-&quot;, &quot;&quot;)  &amp;
&apos;*Contact Name:* &apos; &amp; {!$Record.Contact.Full_name__c}</expression>
    </formulas>
    <formulas>
        <name>IsNewFormula</name>
        <dataType>Boolean</dataType>
        <expression>(NOW() - {!$Record.CreatedDate}) * 86400 &lt; 10</expression>
    </formulas>
    <interviewLabel>Case - Slack Notifications {!$Flow.CurrentDateTime}</interviewLabel>
    <label>Case - Slack Notifications</label>
