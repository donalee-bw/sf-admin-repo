    <start>
        <locationX>50</locationX>
        <locationY>0</locationY>
        <connector>
            <targetReference>Zip_Blank</targetReference>
        </connector>
        <filterFormula>OR(
  AND(
    ISNEW(),
    NOT(ISBLANK( {!$Record.PostalCode} ))
  ),
  AND(
    NOT( ISBLANK( {!$Record.PostalCode} )),
    ISCHANGED( {!$Record.PostalCode} )
  ),
  AND(
    ISBLANK( {!$Record.PostalCode} ),
    ISCHANGED( {!$Record.PostalCode} )
  )
)</filterFormula>
