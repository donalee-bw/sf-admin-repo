    <description>when a lead is created and zip isn&apos;t null, or when a lead&apos;s zip is updated, populate the local customer names and url fields on the lead</description>
    <environments>Default</environments>
    <formulas>
        <name>formulaAccount1NameAndSegment</name>
        <dataType>String</dataType>
        <expression>{!Get_Local_Customer.Account_1_Name__c} + &quot; &quot; + {!formulaAccount1Segment}</expression>
    </formulas>
    <formulas>
        <name>formulaAccount1Segment</name>
        <dataType>String</dataType>
        <expression>IF( {!Get_Local_Customer.Account_1_ID__r.Customer_Segment__c} = &quot;Small&quot;, &quot;(S)&quot;,
IF( {!Get_Local_Customer.Account_1_ID__r.Customer_Segment__c} = &quot;Medium&quot;, &quot;(M)&quot;,
IF( {!Get_Local_Customer.Account_1_ID__r.Customer_Segment__c} = &quot;Large&quot;, &quot;(L)&quot;,
IF( {!Get_Local_Customer.Account_1_ID__r.Customer_Segment__c} = &quot;Multisite&quot;, &quot;(MS)&quot;, &quot;&quot;))))</expression>
    </formulas>
    <formulas>
