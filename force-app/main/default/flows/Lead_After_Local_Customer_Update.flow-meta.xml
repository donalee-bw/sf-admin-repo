IF( {!Get_Local_Customer.Account_3_ID__r.Customer_Segment__c} = &quot;Multisite&quot;, &quot;(MS)&quot;, &quot;&quot;))))</expression>
    </formulas>
    <formulas>
        <name>formulaNormalizedZip</name>
        <dataType>String</dataType>
        <expression>left({!$Record.PostalCode},5)</expression>
    </formulas>
