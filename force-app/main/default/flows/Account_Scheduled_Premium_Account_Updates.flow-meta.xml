    <decisions>
        <description>Checks if both the SaaS Owner and Billing Upsell Owner on the account are active users.</description>
        <name>Needs_Account_Assignment</name>
        <label>Needs Account Assignment?</label>
        <locationX>50</locationX>
        <locationY>360</locationY>
        <defaultConnector>
            <targetReference>Launch_Account_Ownership_Assignment</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>Yes</defaultConnectorLabel>
        <rules>
            <name>No_Needs_Account_Assignment</name>
            <conditionLogic>(1 AND 3) OR (2 AND 4)</conditionLogic>
            <conditions>
                <leftValueReference>$Record.SaaS_Owner__r.IsActive</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <booleanValue>true</booleanValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.Billing_Upsell_Owner__r.IsActive</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <booleanValue>true</booleanValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.SaaS_Owner__r.Name</leftValueReference>
                <operator>NotEqualTo</operator>
                <rightValue>
                    <stringValue>Account Queue</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.Billing_Upsell_Owner__r.Name</leftValueReference>
                <operator>NotEqualTo</operator>
                <rightValue>
                    <stringValue>Account Queue</stringValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Original_Close_Date_Populated</targetReference>
            </connector>
            <label>No</label>
        </rules>
    </decisions>
    <decisions>
        <description>Checks if the number of sites on the school object related to the account is &lt; 10</description>
        <name>Number_of_Sites_10</name>
        <label>Number of Sites &lt; 10 ?</label>
        <locationX>303</locationX>
        <locationY>252</locationY>
        <defaultConnectorLabel>No</defaultConnectorLabel>
        <rules>
            <name>Yes_Number_of_Sites_10</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>$Record.School_Object__r.Number_of_Sites__c</leftValueReference>
                <operator>LessThan</operator>
                <rightValue>
                    <numberValue>10.0</numberValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Needs_Account_Assignment</targetReference>
            </connector>
            <label>Yes</label>
        </rules>
    </decisions>
