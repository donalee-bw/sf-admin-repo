    <description>Sets the fields required for postponement
11/01/24 - PE - Remove Target Launch Date - SaaS field from screen component</description>
    <dynamicChoiceSets>
        <name>choiceSaaSPostponedReason</name>
        <dataType>Picklist</dataType>
        <displayField xsi:nil="true"/>
        <object xsi:nil="true"/>
