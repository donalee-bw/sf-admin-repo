        <picklistObject>Combined_Funnel__c</picklistObject>
    </dynamicChoiceSets>
    <environments>Default</environments>
    <formulas>
        <description>display the combined funnel check-in date if it exists, otherwise Start Date + 30</description>
        <name>forDCheckinDate</name>
        <dataType>Date</dataType>
        <expression>IF( ISNULL( {!Get_Combined_Funnel.SaaS_Postponed_Check_In_Date__c} ), (TODAY()+30), {!Get_Combined_Funnel.SaaS_Postponed_Check_In_Date__c})</expression>
    </formulas>
    <formulas>
        <description>display the combined funnel exit date if it exists, otherwise null</description>
        <name>forDExitDate</name>
        <dataType>Date</dataType>
        <expression>IF( ISNULL( {!Get_Combined_Funnel.SaaS_Postponed_Exit_Date__c} ), NULL, {!Get_Combined_Funnel.SaaS_Postponed_Exit_Date__c})</expression>
    </formulas>
    <formulas>
        <name>forDStartDate</name>
        <dataType>Date</dataType>
        <expression>IF( ISNULL( {!Get_Combined_Funnel.SaaS_Postponed_Start_Date__c} ), TODAY(), {!Get_Combined_Funnel.SaaS_Postponed_Start_Date__c} )</expression>
    </formulas>
    <formulas>
        <name>forTSlackMessage</name>
        <dataType>String</dataType>
        <expression>{!Get_Combined_Funnel.Owner:User.Name} &amp; &apos; is requesting Postponement for &apos; &amp; {!Get_Combined_Funnel.Name} &amp;
SUBSTITUTE({!$Label.NewLine} , &quot;-&quot;, &quot;&quot;) &amp;
&apos;Click here to review the postponement request:&apos; &amp; 
SUBSTITUTE({!$Label.NewLine} , &quot;-&quot;, &quot;&quot;)  &amp;
&apos;&lt;https://brightwheel1.my.salesforce.com/&apos; &amp;{!Get_Combined_Funnel.Id} &amp; &apos;|[View in Salesforce]&gt;&apos;</expression>
    </formulas>
