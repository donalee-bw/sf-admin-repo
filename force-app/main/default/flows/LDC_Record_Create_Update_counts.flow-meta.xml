    <formulas>
        <name>Formula_End_of_current_month</name>
        <dataType>Date</dataType>
        <expression>DATE(
     YEAR(TODAY()),
     MONTH(TODAY()),
     CASE(MONTH(TODAY()), 
          1, 31, 
          2, IF( MOD( YEAR(TODAY()) , 4) = 0, 29, 28), 
          3, 31, 
          4, 30, 
          5, 31, 
          6, 30, 
          7, 31, 
          8, 31, 
          9, 30, 
          10, 31, 
          11, 30, 
          12, 31, 
          0 
     )
)</expression>
    </formulas>
    <formulas>
        <name>Formula_End_of_current_week</name>
        <dataType>Date</dataType>
        <expression>(TODAY() + 7) - MOD(TODAY() - DATE(1900, 1, 7), 7)</expression>
    </formulas>
    <formulas>
        <name>Formula_Start_of_current_month</name>
        <dataType>Date</dataType>
        <expression>DATE( YEAR(TODAY()) , MONTH(TODAY()) , 1)</expression>
    </formulas>
    <formulas>
        <name>Formula_Start_of_current_week</name>
        <dataType>Date</dataType>
        <expression>TODAY() - MOD(TODAY() - DATE(1900,1,8),7)</expression>
    </formulas>
