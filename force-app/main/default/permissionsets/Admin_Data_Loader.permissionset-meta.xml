<?xml version="1.0" encoding="UTF-8"?>
<PermissionSet xmlns="http://soap.sforce.com/2006/04/metadata">
    <customPermissions>
        <enabled>true</enabled>
        <name>Admin_Data_Loader</name>
    </customPermissions>
    <description>This contains the custom permission that bypass flows during data loading</description>
    <fieldPermissions>
        <editable>true</editable>
        <field>Opportunity.Inbound_or_Outbound__c</field>
        <readable>true</readable>
    </fieldPermissions>
    <hasActivationRequired>false</hasActivationRequired>
    <label>Admin Data Loader</label>
    <objectPermissions>
        <allowCreate>false</allowCreate>
        <allowDelete>false</allowDelete>
        <allowEdit>true</allowEdit>
        <allowRead>true</allowRead>
        <modifyAllRecords>false</modifyAllRecords>
        <object>Opportunity</object>
        <viewAllFields>false</viewAllFields>
        <viewAllRecords>false</viewAllRecords>
    </objectPermissions>
    <recordTypeVisibilities>
        <recordType>Opportunity.Experience_Curriculum</recordType>
        <visible>true</visible>
    </recordTypeVisibilities>
</PermissionSet>
