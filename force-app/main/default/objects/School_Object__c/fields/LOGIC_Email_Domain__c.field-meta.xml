<?xml version="1.0" encoding="UTF-8"?>
<CustomField xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>LOGIC_Email_Domain__c</fullName>
    <description>Strip domain from owner email</description>
    <externalId>false</externalId>
    <formula>SUBSTITUTE(Owner_Email__c, LEFT(Owner_Email__c, FIND(&quot;@&quot;, Owner_Email__c)), NULL)</formula>
    <formulaTreatBlanksAs>BlankAsZero</formulaTreatBlanksAs>
    <label>LOGIC Email Domain</label>
    <required>false</required>
    <trackHistory>false</trackHistory>
    <trackTrending>false</trackTrending>
    <type>Text</type>
    <unique>false</unique>
</CustomField>
