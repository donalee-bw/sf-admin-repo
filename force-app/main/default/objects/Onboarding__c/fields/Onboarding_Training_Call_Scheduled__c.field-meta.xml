<?xml version="1.0" encoding="UTF-8"?>
<CustomField xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Onboarding_Training_Call_Scheduled__c</fullName>
    <description>Max date of Training Call Scheduled from either contact or account</description>
    <formula>IF(
    AND(
       NOT(ISBLANK(Account__r.Onboarding_Training_Call_Scheduled__c)),
       ISBLANK(Primary_Contact__r.Onboarding_Training_Call_Scheduled__c)
    ),
    Account__r.Onboarding_Training_Call_Scheduled__c,
    IF(
        AND(
            ISBLANK(Account__r.Onboarding_Training_Call_Scheduled__c),
            NOT(ISBLANK(Primary_Contact__r.Onboarding_Training_Call_Scheduled__c))
        ),
        Primary_Contact__r.Onboarding_Training_Call_Scheduled__c,
        IF(
            Account__r.Onboarding_Training_Call_Scheduled__c &gt; Primary_Contact__r.Onboarding_Training_Call_Scheduled__c,
            Account__r.Onboarding_Training_Call_Scheduled__c,
            Primary_Contact__r.Onboarding_Training_Call_Scheduled__c
        )
    )
)</formula>
    <formulaTreatBlanksAs>BlankAsZero</formulaTreatBlanksAs>
    <label>Onboarding Training Call Scheduled</label>
    <required>false</required>
    <trackHistory>false</trackHistory>
    <trackTrending>false</trackTrending>
    <type>Date</type>
</CustomField>
