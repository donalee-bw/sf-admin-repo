<?xml version="1.0" encoding="UTF-8"?>
<CustomField xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Initial_Setup_Call_Completed__c</fullName>
    <description>Max value from the Onboarding Setup Call fields from contact or account.</description>
    <formula>IF(
    AND(
       NOT(ISBLANK(Account__r.Initial_Setup_Call_Completed__c)),
       ISBLANK(Primary_Contact__r.Initial_Setup_Call_Completed__c)
    ),
    Account__r.Initial_Setup_Call_Completed__c,
    IF(
        AND(
            ISBLANK(Account__r.Initial_Setup_Call_Completed__c),
            NOT(ISBLANK(Primary_Contact__r.Initial_Setup_Call_Completed__c))
        ),
        Primary_Contact__r.Initial_Setup_Call_Completed__c,
        IF(
            Account__r.Initial_Setup_Call_Completed__c &gt; Primary_Contact__r.Initial_Setup_Call_Completed__c,
            Account__r.Initial_Setup_Call_Completed__c,
            Primary_Contact__r.Initial_Setup_Call_Completed__c
        )
    )
)</formula>
    <label>Initial Setup Call Completed</label>
    <required>false</required>
    <trackHistory>false</trackHistory>
    <trackTrending>false</trackTrending>
    <type>Date</type>
</CustomField>
