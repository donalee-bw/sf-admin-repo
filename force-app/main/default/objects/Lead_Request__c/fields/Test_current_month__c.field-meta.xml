<?xml version="1.0" encoding="UTF-8"?>
<CustomField xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Test_current_month__c</fullName>
    <formula>AND(
    YEAR(DATEVALUE(Date_Time_of_request__c)) = YEAR(TODAY()),
    MONTH(DATEVALUE(Date_Time_of_request__c)) = MONTH(TODAY())
)</formula>
    <formulaTreatBlanksAs>BlankAsZero</formulaTreatBlanksAs>
    <label>Test current month</label>
    <trackHistory>false</trackHistory>
    <trackTrending>false</trackTrending>
    <type>Checkbox</type>
</CustomField>
