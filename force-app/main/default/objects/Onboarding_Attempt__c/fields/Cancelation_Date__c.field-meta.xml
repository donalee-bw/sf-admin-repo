<?xml version="1.0" encoding="UTF-8"?>
<CustomField xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Cancelation_Date__c</fullName>
    <formula>IF(
ISPICKVAL(Onboarding_Attempt_Status_New__c , &quot;Closed&quot;) || ISPICKVAL(Onboarding_Attempt_Status_New__c , &quot;Canceled&quot;),
Cancelation_Date_Stamp__c,
IF(NOT(ISBLANK( Cancelation_Date_Stamp__c   )),
Cancelation_Date_Stamp__c ,
Account__r.School_Object__r.Cancellation_Date__c )
)</formula>
    <label>Cancelation Date</label>
    <required>false</required>
    <trackHistory>false</trackHistory>
    <trackTrending>false</trackTrending>
    <type>Date</type>
</CustomField>
