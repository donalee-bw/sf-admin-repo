<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Billing_Postponed_Required_Fields</fullName>
    <active>true</active>
    <description>Fields that are required when the Billing Onboarding Status is set to &apos;Postponed&apos;.</description>
    <errorConditionFormula>AND(
   NOT($User.ProfileId = &apos;00e1I000001rqxt&apos;),
   NOT($User.ProfileId = &apos;00e1I000000qsnN&apos;),
   ISPICKVAL(Billing_Onboarding_Status__c,&apos;Postponed&apos;),
   OR(
      ISBLANK(Billing_Postponed_Reason__c),
      ISNULL(Billing_Postponed_Check_In_Date__c)
    )
 )</errorConditionFormula>
    <errorDisplayField>Billing_Postponed_Reason__c</errorDisplayField>
    <errorMessage>Billing Postponed Reason and Billing Postponed Check-In Date are required when Billing Onboarding Status is set to &apos;Postponed&apos;.</errorMessage>
</ValidationRule>
