<?xml version="1.0" encoding="UTF-8"?>
<CustomField xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Billing_Verification_Within_72_Hours__c</fullName>
    <description>Checked if Billing Submit Verify Stage Met Date is within 3 days of Opp CW date. Used for BNP comp</description>
    <formula>AND(
NOT(ISBLANK(Account__r.School_Object__r.Billing_Submit_Verify_Stage_Met_Date__c)),
NOT(ISBLANK(Original_Close_Date__c)),
DATEVALUE(Account__r.School_Object__r.Billing_Submit_Verify_Stage_Met_Date__c) - Original_Close_Date__c &lt;= 4
)</formula>
    <formulaTreatBlanksAs>BlankAsZero</formulaTreatBlanksAs>
    <label>Billing Verification Within 72 Hours</label>
    <trackHistory>false</trackHistory>
    <trackTrending>false</trackTrending>
    <type>Checkbox</type>
</CustomField>
